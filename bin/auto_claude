    _jq_update --argjson f "$parsed" \
      '.semantic.doc_update_summary = $f'
    log OK "Doc update summary saved to state"
    return 0
  fi

  local extracted
  extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n '/^```\(json\)\{0,1\}$/,/^```$/p' | sed '1d;$d')
  if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
    _jq_update --argjson f "$parsed" \
      '.semantic.doc_update_summary = $f'
    log OK "Doc update summary saved to state (from markdown fence)"
    return 0
  fi

  log WARN "Could not parse doc update summary"
}

# ─── Escalation Prompt Builders ─────────────────────────────────────────────
#
# Used by the tiered escalation loop in phase_test_fix when ESCALATION_ENABLED=true.

# Tier 2: Re-anchor with spec intent, decisions, approach journal, and intent map.
_build_reanchor_prompt() {
  local truncated_output="$1"

  local spec_content=""
  [ -f "$SPEC_FILE" ] && spec_content="$(cat "$SPEC_FILE")"

  local decisions=""
  decisions=$(_state_get '.semantic.decisions_manifest // empty')
  if [ -n "$decisions" ]; then
    decisions=$(echo "$decisions" | jq -r '
      [ (.deliverables // [])[] |
        .title + ":\n" +
        ([ (.decisions // [])[] | "  - " + .choice + " (" + .rationale + ")" ] | join("\n"))
      ] | join("\n\n")
    ' 2>/dev/null) || decisions=""
  fi

  local journal=""
  journal=$(_format_approach_journal)

  # Intent map section (from D4 — graceful if absent)
  local intent_section=""
  local intent_map
  intent_map=$(_state_get '.semantic.intent_map // empty')
  if [ -n "$intent_map" ] && [ "$intent_map" != "null" ]; then
    intent_section=$(echo "$intent_map" | jq -r '
      "INTENT MAP: These tests encode the acceptance criteria:\n" +
      ([ .[] |
        ([ (.intents // [])[] |
          "- [" + (.layer // "?") + "] " + .test_name + ": " + .expected_behaviour
        ] | join("\n"))
      ] | join("\n"))
    ' 2>/dev/null) || intent_section=""
  fi

  local iteration_count=$((TIER_2_AT - 1))

  echo "IMPORTANT: You have failed to fix these tests ${iteration_count} times.
Before attempting another fix, re-read the original intent and your decisions.

ORIGINAL SPEC:
${spec_content}

YOUR DECISIONS:
${decisions:-"(not available)"}

${journal}

${intent_section}

CURRENT FAILURES:
Failed suites: ${LAST_FAILED_SUITES}
Passed suites: ${LAST_PASSED_SUITES}

\`\`\`
${truncated_output}
\`\`\`

Re-evaluate: is your current approach sound, or is there a design-level issue
that tactical fixes cannot resolve? If the approach is wrong, describe what needs
to change fundamentally before attempting the fix. Then fix the code."
}

# Tier 3: Self-contained prompt for a fresh consultation session.
_build_consultation_prompt() {
  local truncated_output="$1"

  local spec_intent
  spec_intent=$(_state_get '.semantic.plan_intent // "(not extracted)"')

  local journal=""
  journal=$(_format_approach_journal)

  local changed_files=""
  changed_files=$(_state_get '[ (.deterministic.files_changed // [])[] ] | join(", ")')

  # Intent map for intent-vs-reality section
  local intent_vs_reality=""
  local intent_map
  intent_map=$(_state_get '.semantic.intent_map // empty')
  if [ -n "$intent_map" ] && [ "$intent_map" != "null" ]; then
    intent_vs_reality=$(echo "$intent_map" | jq -r --arg failed "$LAST_FAILED_SUITES" '
      "INTENT vs REALITY:\n" +
      ([ .[] | .intents[]? |
        "- INTENT: \"" + .test_name + "\"\n  EXPECTED: " + .expected_behaviour + "\n  STATUS: " +
        (if ($failed | contains(.test_name)) then "FAILING" else "UNKNOWN" end)
      ] | join("\n"))
    ' 2>/dev/null) || intent_vs_reality=""
  fi

  # File tree (limited to 300 entries)
  local file_tree=""
  file_tree=$(find "$PROJECT_ROOT" \( -name '*.ts' -o -name '*.tsx' -o -name '*.py' -o -name '*.ex' -o -name '*.exs' -o -name '*.go' -o -name '*.rs' \) -not -path '*/node_modules/*' -not -path '*/.git/*' 2>/dev/null | head -300)

  echo "You are an architectural consultant reviewing a stuck implementation.

GOAL: ${spec_intent}

FILES CHANGED: ${changed_files}

${journal}

${intent_vs_reality}

PROJECT FILE TREE (sample):
${file_tree}

CURRENT TEST FAILURES:
Failed suites: ${LAST_FAILED_SUITES}

\`\`\`
${truncated_output}
\`\`\`

Diagnose why the current approach is failing and propose 2-3 alternative approaches.
Output ONLY valid JSON (no markdown fences, no commentary):
{
  \"diagnosis\": \"1-3 sentences on why the current approach is failing\",
  \"alternatives\": [
    {
      \"id\": \"A\",
      \"summary\": \"One-line description\",
      \"approach\": \"2-3 sentences on what would change architecturally\",
      \"why_it_might_work\": \"Why this avoids the root cause\",
      \"files_affected\": [\"file1.ts\"],
      \"risk\": \"What could go wrong\",
      \"confidence\": \"high|medium|low\"
    }
  ]
}"
}

# Build structured intent-vs-reality gap analysis for the human checkpoint.
_build_intent_gap_analysis() {
  local intent_map
  intent_map=$(_state_get '.semantic.intent_map // empty')

  if [ -n "$intent_map" ] && [ "$intent_map" != "null" ]; then
    echo "$intent_map" | jq -r --arg failed "$LAST_FAILED_SUITES" '
      "Intent Gap Analysis:\n" +
      ([ .[] | .intents[]? |
        (if ($failed | contains(.test_name)) then
          "  FAILING: " + .test_name + "\n    Expected: " + .expected_behaviour
        else empty end)
      ] | if length == 0 then "  (no intent map entries match failing suites)"
          else join("\n") end)
    ' 2>/dev/null || echo "Intent Gap Analysis: (could not parse intent map)"
  else
    echo "Intent Gap Analysis: (no structured intent map available)
  Failing suites: ${LAST_FAILED_SUITES}"
  fi
}

# Tier 4: Present alternatives to the human, read their choice.
_present_alternatives() {
  local truncated_output="$1"

  local gap_analysis
  gap_analysis=$(_build_intent_gap_analysis)

  local diagnosis
  diagnosis=$(_state_get '.deterministic.escalation.diagnosis // "(no diagnosis)"')

  local journal=""
  journal=$(_format_approach_journal)

  local alternatives_display
  alternatives_display=$(jq -r '
    [ (.deterministic.escalation.alternatives // [])[] |
      "  " + .id + ") " + .summary + " (confidence: " + .confidence + ", files: " + (.files_affected | length | tostring) + ")\n" +
      "     " + .approach
    ] | join("\n\n")
  ' "$STATE_FILE" 2>/dev/null) || alternatives_display="(no alternatives available)"

  # Print to terminal (stderr so it shows even when stdout is captured)
  cat >&2 <<EOF

══════════════════════════════════════════════════════════════
TEST-FIX ESCALATION: Implementation stuck after $((TIER_4_AT - 1)) iterations.

${gap_analysis}

Diagnosis: ${diagnosis}

What was tried:
${journal:-"(no approach journal)"}

Alternatives:
${alternatives_display}

Enter A/B/C to try an alternative, R to retry current approach,
or Q to abort pipeline:
══════════════════════════════════════════════════════════════
EOF

  local choice=""
  read -r choice
  echo "$choice"
}

# Resume implementation with a chosen alternative approach.
_resume_with_alternative() {
  local alt_json="$1"
  local truncated_output="$2"

  local alt_id alt_summary alt_approach alt_files
  alt_id=$(echo "$alt_json" | jq -r '.id // "?"')
  alt_summary=$(echo "$alt_json" | jq -r '.summary // ""')
  alt_approach=$(echo "$alt_json" | jq -r '.approach // ""')
  alt_files=$(echo "$alt_json" | jq -r '[ .files_affected // [] | .[] ] | join(", ")')

  # Record the choice in state
  _jq_update --arg id "$alt_id" '.deterministic.escalation.chosen = $id'

  run_claude "CHANGE OF APPROACH. The previous approach failed repeatedly.

NEW APPROACH (${alt_id}): ${alt_summary}
${alt_approach}

FILES TO CHANGE: ${alt_files}

CURRENT FAILURES:
Failed suites: ${LAST_FAILED_SUITES}
Passed suites: ${LAST_PASSED_SUITES}

\`\`\`
${truncated_output}
\`\`\`

Re-implement the failing section using this new approach.
Do NOT continue with the old approach.
Make the failing tests pass."
}

# ─── Pattern Conformance ────────────────────────────────────────────────────
#
# Called within phase_skill_chain to check implementation against derived patterns.

_run_pattern_conformance() {
  local baseline
  baseline=$(_state_get '.semantic.pattern_baseline // empty')
  if [ -z "$baseline" ] || [ "$baseline" = "null" ]; then
    log INFO "No pattern baseline — skipping conformance review"
    return 0
  fi

  local existing_deviations
  existing_deviations=$(_state_get '[ (.semantic.pattern_baseline.existing_deviations // [])[] | "- " + .file + ":" + (.line | tostring) + ": " + .comment ] | join("\n")')

  run_claude "IMPORTANT: Tests have already passed. Do NOT re-run tests.

Review all changed files for PATTERN CONFORMANCE against this baseline:

${baseline}

Previously accepted deviations (do NOT re-litigate these unless the
surrounding code has changed enough to invalidate the rationale):
${existing_deviations:-"(none)"}

For each pattern in the baseline, check whether your implementation conforms.
For each DEVIATION you find:
1. State what the existing pattern is and what you did differently
2. List PROS of the new approach (be honest — real benefits only)
3. List CONS of the new approach (focus on consistency cost, maintenance burden,
   reader confusion, contract violations)
4. Verdict: if cons outweigh pros → REVERT to existing pattern and make the change.
   If pros outweigh → KEEP but add a PATTERN-DEVIATION comment at the deviation site.

The bar for keeping a deviation is: \"this is meaningfully better AND the existing
pattern cannot accommodate the requirement.\" Pattern consistency has inherent value
that must be overcome.

After reviewing and acting on all deviations, output a JSON summary.
Output ONLY valid JSON (no markdown fences, no commentary):
{
  \"deviations\": [
    {
      \"id\": \"DEV-001\",
      \"pattern_id\": \"P001\",
      \"area\": \"description\",
      \"existing_pattern\": \"what the codebase does\",
      \"implementation_pattern\": \"what was implemented\",
      \"pros\": [\"...\"],
      \"cons\": [\"...\"],
      \"verdict\": \"revert|keep\",
      \"rationale\": \"1-2 sentences on why this verdict\",
      \"action_taken\": \"what was changed (if revert) or comment added (if keep)\"
    }
  ],
  \"conforms\": [\"P002\", \"P003\"]
}"
}

_extract_conformance_findings() {
  log INFO "Extracting conformance findings..."

  local parsed=""
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      _jq_update --argjson c "$parsed" '.semantic.conformance_findings = $c'
      _ensure_explain_dir
      echo "$parsed" > "$EXPLAIN_DIR/conformance_findings.json"
      log OK "Conformance findings saved to state"

      # Log per-pattern summary
      local summary
      summary=$(echo "$parsed" | jq -r '
        ([ (.conforms // [])[] | "  ✓ " + . + ": conforms" ] | join("\n")) +
        "\n" +
        ([ (.deviations // [])[] |
          "  ✗ " + .area + ": DEVIATION → verdict: " + .verdict +
          (if .verdict == "revert" then " → reverted" else " (documented)" end)
        ] | join("\n"))
      ' 2>/dev/null) || summary=""
      [ -n "$summary" ] && log INFO "Pattern conformance:\n${summary}"
      return 0
    fi
  fi

  log WARN "Could not parse conformance findings"
}

# ─── Context Pack Builder ────────────────────────────────────────────────────
#
# Assembles a tailored markdown prompt from the state file for each quality phase.
# Each phase gets different context:
#   skill_chain:     intent + files + test status (needs intent to judge correctness)
#   loc_enforcement: files + prior findings (mechanical — doesn't need intent)
#   fresh_review:    files + prior phases only, NO intent (cold review, avoids anchoring)
#   doc_update:      intent + files + all prior findings (needs to know the feature)
#   final:           full state (produces human-readable summary)

_build_context_pack() {
  local phase="$1"

  case "$phase" in
    skill_chain)
      jq -r '
        "## Session Context\n\n" +
        "**Goal:** " + (.semantic.plan_intent // "(not extracted)") + "\n\n" +
        "**Implementation:** " + (.semantic.implementation_summary // "(not extracted)") + "\n\n" +
        "**Key decisions:**\n" +
          ([ (.semantic.key_decisions // [])[] | "- " + .decision + ": " + .rationale ] | join("\n")) + "\n\n" +
        "**Files changed:**\n" +
          ([ (.deterministic.files_changed // [])[] | "- " + . ] | join("\n")) + "\n\n" +
        "**Test status:** " + (.deterministic.test_results.final_status // "unknown") +
          " after " + ((.deterministic.test_results.iterations_needed // 0) | tostring) + " iteration(s).\n" +
        (.semantic.test_fix_summary // "") + "\n\n" +
        "**Approach journal:**\n" +
          ([ (.deterministic.approach_journal // [])[] |
             "- Iteration " + (.iteration | tostring) + ": " + .summary +
             " [error: " + .error_class + "]" ]
           | if length == 0 then "(no iterations needed)" else join("\n") end) + "\n\n" +
        "**CI checks:** " + (.deterministic.ci_checks_results.final_status // "pending") +
          " (auto-fixed: " +
          ([ (.deterministic.ci_checks_results.auto_fixed // [])[] ] | if length == 0 then "none" else join(", ") end) +
          ", Claude-fixed: " +
          ([ (.deterministic.ci_checks_results.claude_fixed // [])[] ] | if length == 0 then "none" else join(", ") end) +
          ")" + "\n\n" +
        "**Coverage gaps:**\n" +
          (if (.semantic.coverage_map | type) == "object" then
            ([ (.semantic.coverage_map.uncovered // [])[] | "- [" + .severity + "] " + .requirement + ": " + .reason ] | if length == 0 then "(none)" else join("\n") end)
          else "(not captured)" end) + "\n\n" +
        "**Unverified assumptions:**\n" +
          (if (.semantic.assumptions_carried_forward | type) == "array" and ((.semantic.assumptions_carried_forward | length) > 0) then
            ([ (.semantic.assumptions_carried_forward)[] | "- " + .assumption + " (impact if wrong: " + .impact_if_wrong + ")" ] | join("\n"))
          else "(none)" end)
      ' "$STATE_FILE" 2>/dev/null || echo "## Session Context

(state unavailable — review the changed files directly)"
      ;;

    loc_enforcement)
      jq -r '
        "## Session Context\n\n" +
        "**Completed quality phases:** " +
          ([ (.semantic.completed_quality_phases // [])[] ] | if length == 0 then "none" else join(", ") end) + "\n\n" +
        "**Files changed:**\n" +
          ([ (.deterministic.files_changed // [])[] | "- " + . ] | join("\n"))
      ' "$STATE_FILE" 2>/dev/null || echo "## Session Context

(state unavailable)"
      ;;

    fresh_review)
      # NO intent — cold review to avoid anchoring bias.
      # Includes prior quality phases so the reviewer doesn't re-report fixed issues.
      # Also includes impact assessment and assumptions for the cold reviewer to challenge.
      {
        jq -r '
          "## Session Context\n\n" +
          "**Completed quality phases:** " +
            ([ (.semantic.completed_quality_phases // [])[] ] | if length == 0 then "none" else join(", ") end) + "\n\n" +
          "**Files changed:**\n" +
            ([ (.deterministic.files_changed // [])[] | "- " + . ] | join("\n")) + "\n\n" +
          "**Files created:**\n" +
            ([ (.deterministic.files_created // [])[] | "- " + . ] | join("\n"))
        ' "$STATE_FILE" 2>/dev/null || echo "## Session Context

(state unavailable)"

        # Inject impact assessment if available
        if [ -f "$EXPLAIN_DIR/impact_assessment.md" ]; then
          echo ""
          echo "**Impact Assessment:**"
          cat "$EXPLAIN_DIR/impact_assessment.md"
        fi
        # Inject assumptions for the cold reviewer to challenge
        if [ -f "$EXPLAIN_DIR/assumptions.json" ]; then
          local assumptions_content
          assumptions_content=$(cat "$EXPLAIN_DIR/assumptions.json" 2>/dev/null)
          if [ -n "$assumptions_content" ] && [ "$assumptions_content" != "[]" ]; then
            echo ""
            echo "**Unverified Assumptions (challenge these):**"
            echo '```json'
            echo "$assumptions_content"
            echo '```'
          fi
        fi

        # Inject pattern deviation findings for the cold reviewer to challenge
        if [ -f "$EXPLAIN_DIR/conformance_findings.json" ]; then
          local deviations_display
          deviations_display=$(jq -r '
            ([ (.deviations // [])[] |
              (if .verdict == "revert" then
                "- [REVERTED] " + .area + ": " + .action_taken
              else
                "- [KEPT] " + .area + ": " + .rationale + ". Challenge this if you disagree."
              end)
            ] | if length == 0 then "" else join("\n") end)
          ' "$EXPLAIN_DIR/conformance_findings.json" 2>/dev/null) || deviations_display=""
          if [ -n "$deviations_display" ]; then
            echo ""
            echo "**Pattern Deviations:**"
            echo "$deviations_display"
          fi
        fi
      }
      ;;

    doc_update)
      jq -r '
        "## Session Context\n\n" +
        "**Goal:** " + (.semantic.plan_intent // "(not extracted)") + "\n\n" +
        "**Implementation:** " + (.semantic.implementation_summary // "(not extracted)") + "\n\n" +
        "**Completed quality phases:** " +
          ([ (.semantic.completed_quality_phases // [])[] ] | if length == 0 then "none" else join(", ") end) + "\n\n" +
        "**Files changed:**\n" +
          ([ (.deterministic.files_changed // [])[] | "- " + . ] | join("\n")) + "\n\n" +
        "**Files created:**\n" +
          ([ (.deterministic.files_created // [])[] | "- " + . ] | join("\n"))
      ' "$STATE_FILE" 2>/dev/null || echo "## Session Context

(state unavailable)"
      ;;

    final|*)
      # Full state for summary generation or unknown phases
      jq -r '
        "## Session Summary\n\n" +
        "**Goal:** " + (.semantic.plan_intent // "(not extracted)") + "\n" +
        "**Governance:** " +
          ([ (.semantic.governance_ids // [])[] ] | if length == 0 then "none" else join(", ") end) + "\n\n" +
        "**Plan:**\n" +
          ([ (.semantic.plan_checklist // [])[] | "- " + . ] | join("\n")) + "\n\n" +
        "**Implementation:** " + (.semantic.implementation_summary // "(not extracted)") + "\n\n" +
        "**Key decisions:**\n" +
          ([ (.semantic.key_decisions // [])[] | "- " + .decision + ": " + .rationale ] | join("\n")) + "\n\n" +
        "**Test results:** " + (.deterministic.test_results.final_status // "unknown") +
          " after " + ((.deterministic.test_results.iterations_needed // 0) | tostring) + " iteration(s).\n" +
        (.semantic.test_fix_summary // "") + "\n\n" +
        "**Approach journal:**\n" +
          ([ (.deterministic.approach_journal // [])[] |
             "- Iteration " + (.iteration | tostring) + ": " + .summary +
             " [error: " + .error_class + "]" ]
           | if length == 0 then "(no iterations needed)" else join("\n") end) + "\n\n" +
        "**Escalation:** " +
          (if ((.deterministic.escalation.tier_reached // 0) > 1) then
            "Reached tier " + ((.deterministic.escalation.tier_reached) | tostring) + ". " +
            "Diagnosis: " + (.deterministic.escalation.diagnosis // "(none)") + ". " +
            "Chosen alternative: " + (.deterministic.escalation.chosen // "none")
          else "No escalation needed" end) + "\n\n" +
        "**CI checks:** " + (.deterministic.ci_checks_results.final_status // "pending") +
          " (auto-fixed: " +
          ([ (.deterministic.ci_checks_results.auto_fixed // [])[] ] | if length == 0 then "none" else join(", ") end) +
          ", Claude-fixed: " +
          ([ (.deterministic.ci_checks_results.claude_fixed // [])[] ] | if length == 0 then "none" else join(", ") end) +
          ")\n\n" +
        "**Files changed:**\n" +
          ([ (.deterministic.files_changed // [])[] | "- " + . ] | join("\n")) + "\n\n" +
        "**Files created:**\n" +
          ([ (.deterministic.files_created // [])[] | "- " + . ] | join("\n")) + "\n\n" +
        "**Skill chain (code review + security + simplification):**\n" +
          (if (.semantic.skill_chain_findings | type) == "object" then
            "Code review issues fixed:\n" +
              ([ (.semantic.skill_chain_findings.code_review_issues // [])[] | "- " + . ] | join("\n")) + "\n" +
            "Security: " + (.semantic.skill_chain_findings.security_assessment // "(not captured)") + "\n" +
            "Simplifications:\n" +
              ([ (.semantic.skill_chain_findings.simplifications // [])[] | "- " + . ] | join("\n")) + "\n" +
            "Verified clean:\n" +
              ([ (.semantic.skill_chain_findings.verified_clean // [])[] | "- " + . ] | join("\n"))
          else "(not captured)" end) + "\n\n" +
        "**Pattern conformance:**\n" +
          (if (.semantic.conformance_findings | type) == "object" then
            "Reverted:\n" +
              ([ (.semantic.conformance_findings.deviations // [])[] | select(.verdict == "revert") | "- " + .area + ": " + .action_taken ] | if length == 0 then "(none)\n" else join("\n") + "\n" end) +
            "Kept (with PATTERN-DEVIATION comment):\n" +
              ([ (.semantic.conformance_findings.deviations // [])[] | select(.verdict == "keep") | "- " + .area + ": " + .rationale ] | if length == 0 then "(none)" else join("\n") end)
          else "(not captured)" end) + "\n\n" +
        "**Fresh review findings:**\n" +
          (if (.semantic.review_findings | type) == "object" then
            "Issues fixed:\n" +
              ([ (.semantic.review_findings.issues_fixed // [])[] | "- " + . ] | join("\n")) + "\n" +
            "Warnings / known limitations:\n" +
              ([ (.semantic.review_findings.warnings // [])[] | "- " + . ] | join("\n")) + "\n" +
            "Approved files:\n" +
              ([ (.semantic.review_findings.approved_files // [])[] | "- " + . ] | join("\n"))
          else "(not captured)" end) + "\n\n" +
        "**Documentation updates:**\n" +
          (if (.semantic.doc_update_summary | type) == "object" then
            "Updated:\n" +
              ([ (.semantic.doc_update_summary.docs_updated // [])[] | "- " + .file + ": " + .changes ] | join("\n")) + "\n" +
            "Unchanged:\n" +
              ([ (.semantic.doc_update_summary.docs_unchanged // [])[] | "- " + . ] | join("\n"))
          else "(not captured)" end)
      ' "$STATE_FILE" 2>/dev/null || echo "## Session Summary

(state unavailable)"
      ;;
  esac
}

# ─── Changed File Detection ──────────────────────────────────────────────────

get_changed_files() {
  if [ "$HAS_GIT" = false ]; then
    log WARN "No git repo — cannot detect changed files."
    return 0
  fi
  cd "$PROJECT_ROOT"

  # Diff tracked files against the baseline commit captured at pipeline start.
  # This covers committed + staged + unstaged changes made during this session,
  # without picking up pre-existing dirty state from before the pipeline ran.
  local tracked_changes=""
  if [ -n "$BASELINE_COMMIT" ]; then
    tracked_changes=$(git diff --name-only "$BASELINE_COMMIT" 2>/dev/null)
  else
    # No baseline (shouldn't happen) — fall back to unstaged + staged
    tracked_changes=$(git diff --name-only 2>/dev/null; git diff --cached --name-only 2>/dev/null)
  fi

  # For untracked files: subtract the baseline snapshot so only files created
  # during this session appear. Without this, every pre-existing untracked file
  # (specs, skills/, data files) pollutes the list.
  local current_untracked new_untracked=""
  current_untracked=$(git ls-files --others --exclude-standard 2>/dev/null)
  if [ -f "$BASELINE_FILE" ]; then
    # comm requires sorted input; baseline file is already sorted
    new_untracked=$(comm -23 <(echo "$current_untracked" | sort) <(sort "$BASELINE_FILE"))
  else
    new_untracked="$current_untracked"
  fi

  { echo "$tracked_changes"; echo "$new_untracked"; } | sed '/^$/d' | sort -u
}

# ─── Test Suite Infrastructure ───────────────────────────────────────────────
#
# Projects define test_suite_*() functions in .auto_claude.conf. The core
# auto-discovers all of them, runs each independently, and reports per-suite
# pass/fail. This gives targeted fix prompts (Claude knows which suite failed)
# and loud failure on misconfiguration (wrong path shows the suite name).

_discover_test_suites() {
  declare -F | awk '{print $3}' | grep '^test_suite_' || true
}

# Per-suite exit codes and outputs, keyed by suite name.
# Used by _diagnose_suite_failure to inspect individual failures.
# Using declare -A inside a function scope to avoid set -u issues at top level.
# Temp directory for per-suite outputs and exit codes (avoids associative arrays).
_SUITE_TMP_DIR=""

_suite_tmp_dir() {
  if [ -z "$_SUITE_TMP_DIR" ] || [ ! -d "$_SUITE_TMP_DIR" ]; then
    _SUITE_TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/ac_suites.XXXXXX")
  fi
  echo "$_SUITE_TMP_DIR"
}

_get_suite_exit() {
  local name="$1"
  local f="$(_suite_tmp_dir)/${name}.exit"
  [ -f "$f" ] && cat "$f" || echo "1"
}

_get_suite_output() {
  local name="$1"
  local f="$(_suite_tmp_dir)/${name}.out"
  [ -f "$f" ] && cat "$f" || echo ""
}

_run_all_suites() {
  # Re-source conf before each test run to pick up env var changes
  # (e.g. PGHOST/PGPORT fixes added mid-run)
  if [ -f "$CONF_FILE" ]; then
    source "$CONF_FILE"
  fi

  local suites
  suites=$(_discover_test_suites)

  LAST_PASSED_SUITES=""
  LAST_FAILED_SUITES=""
  LAST_TEST_OUTPUT=""

  local any_failed=0

  for suite in $suites; do
    local name="${suite#test_suite_}"

    # Skip suites previously diagnosed as unfixable environment issues
    local _skip_reason=""
    if [ -n "$_ENV_SKIP_SUITES" ]; then
      _skip_reason=$(echo "$_ENV_SKIP_SUITES" | tr ',' '\n' | grep "^${name}=" | head -1 | cut -d= -f2-)
    fi
    if [ -n "$_skip_reason" ]; then
      log WARN "Suite ${name}: SKIPPED (env: ${_skip_reason})"
      LAST_PASSED_SUITES+="${name} "
      LAST_TEST_OUTPUT+="
=== Suite: ${name} (SKIPPED — env issue: ${_skip_reason}) ==="
      continue
    fi

    log INFO "Running test suite: ${name}..."
    local suite_output suite_exit=0
    local idle_timeout="${SUITE_IDLE_TIMEOUT:-0}"

    if [ "$idle_timeout" -gt 0 ]; then
      # Idle timeout: kill the suite if its output file hasn't grown in N seconds.
      # This allows long-running suites that are actively producing output (e.g.
      # 750 mocha tests) to complete, while killing suites that hang silently
      # (e.g. waiting for a missing database, stuck compilation).
      local outfile="$(_suite_tmp_dir)/${name}.running"
      "$suite" > "$outfile" 2>&1 &
      local suite_pid=$!
      local idle_elapsed=0
      local last_size=0

      while kill -0 "$suite_pid" 2>/dev/null; do
        sleep 2
        local current_size
        current_size=$(wc -c < "$outfile" 2>/dev/null || echo "0")
        current_size="${current_size##* }"  # trim whitespace (macOS wc)

        if [ "$current_size" -ne "$last_size" ]; then
          # Output is growing — reset idle counter
          idle_elapsed=0
          last_size="$current_size"
        else
          idle_elapsed=$((idle_elapsed + 2))
        fi

        if [ $idle_elapsed -ge "$idle_timeout" ]; then
          kill -9 "$suite_pid" 2>/dev/null
          wait "$suite_pid" 2>/dev/null || true
          suite_exit=124
          suite_output=$(cat "$outfile" 2>/dev/null)
          suite_output+=$'\n'"[auto_claude] Suite '${name}' killed — no output for ${idle_timeout}s (idle timeout)"
          log WARN "Suite ${name}: IDLE TIMEOUT — no output for ${idle_timeout}s"
          rm -f "$outfile"
          break
        fi
      done

      # Normal completion (process exited before timeout)
      if [ $suite_exit -ne 124 ]; then
        wait "$suite_pid" 2>/dev/null || suite_exit=$?
        suite_output=$(cat "$outfile" 2>/dev/null)
        rm -f "$outfile"
      fi
    else
      suite_output=$("$suite" 2>&1) || suite_exit=$?
    fi

    # Store per-suite results in temp files (avoids associative array + set -u issues)
    echo "$suite_exit" > "$(_suite_tmp_dir)/${name}.exit"
    echo "$suite_output" > "$(_suite_tmp_dir)/${name}.out"

    LAST_TEST_OUTPUT+="
=== Suite: ${name} (exit ${suite_exit}) ===
${suite_output}"

    if [ $suite_exit -eq 0 ]; then
      LAST_PASSED_SUITES+="${name} "
      log OK "Suite ${name}: PASS"
    else
      LAST_FAILED_SUITES+="${name} "
      log WARN "Suite ${name}: FAIL"
      any_failed=1
    fi
  done

  return $any_failed
}

# ─── Environment Diagnostic ──────────────────────────────────────────────────
#
# Before burning Claude iterations on test failures, check if the failure is
# environmental (command not found, tool shadowing, missing database, missing
# runtime). Environment issues can't be fixed by editing source code.
#
# _diagnose_suite_failure returns one of:
#   "code"        — normal code failure, send to Claude
#   "cmd_missing"  — binary not found (exit 127)
#   "tool_shadow" — wrong binary found (e.g. Python dotenv vs Node dotenv-cli)
#   "db_missing"  — database does not exist
#   "env_missing" — runtime environment not active (devenv, nix, etc.)
#   "timeout"     — suite idle-timed out (exit 124)
#
# _attempt_env_fix modifies the suite function in-memory to fix known patterns.
# Fixes are logged to ENV_FIX_LOG so the user can make them permanent.

ENV_FIX_LOG="${PROJECT_ROOT}/.auto_claude_env_fixes.log"

# Suites that have been diagnosed as unfixable environment issues.
# Comma-delimited "name=diagnosis" pairs. Using a flat string instead of
# associative arrays because bash 3.x (macOS default) lacks them, and
# bash 4.x+ with set -u treats unset keys as unbound variable errors.
_ENV_SKIP_SUITES=""

_diagnose_suite_failure() {
  local name="$1" exit_code="$2" output="$3"
  local diagnosis="code"

  # Exit 124 = timeout (from timeout command or our background job killer)
  if [ "$exit_code" -eq 124 ]; then
    diagnosis="timeout"

  # Exit 127 = command not found
  elif [ "$exit_code" -eq 127 ]; then
    diagnosis="cmd_missing"

  # Database does not exist (PostgreSQL, MySQL, SQLite patterns)
  elif echo "$output" | grep -qiE '(database "?[a-z_]+"? does not exist|Unknown database|no such table|relation .* does not exist.*CREATE)'; then
    diagnosis="db_missing"

  # Tool shadowing: Python dotenv intercepting Node dotenv-cli
  # Python's dotenv treats -e as --export (boolean), not env file path
  elif echo "$output" | grep -qiE '(python.*dotenv|dotenv.*usage:.*\[-e\]|unrecognized arguments.*\.env)'; then
    diagnosis="tool_shadow"

  # devenv / nix shell not active (multiple missing commands, or specific markers)
  elif [ "$exit_code" -eq 127 ] || echo "$output" | grep -qiE '(devenv.*not found|nix.*not found|elixir.*not found|mix.*not found|erl.*not found)'; then
    # Strengthen: if we see the binary name in the "not found" message
    if echo "$output" | grep -qiE '(command not found|No such file or directory)'; then
      diagnosis="cmd_missing"
    fi
  fi

  echo "$diagnosis"
}

_attempt_env_fix() {
  local name="$1" diagnosis="$2" output="$3"
  local fixed=false
  local fix_description=""

  case "$diagnosis" in
    cmd_missing)
      # Extract the missing command name from output
      local missing_cmd=""
      missing_cmd=$(echo "$output" | grep -oE '[a-z_-]+: (command )?not found' | head -1 | awk -F: '{print $1}')
      [ -z "$missing_cmd" ] && missing_cmd=$(echo "$output" | grep -oE 'No such file or directory.*?([a-z_-]+)' | head -1 | awk '{print $NF}')

      if [ -z "$missing_cmd" ]; then
        log WARN "env_fix: Could not extract missing command name from output"
        return 1
      fi

      log INFO "env_fix: Looking for '${missing_cmd}' in common locations..."

      # Search common locations
      local found_path=""
      local search_dirs=(
        "$HOME/bin"
        "${PROJECT_ROOT}/node_modules/.bin"
        "${PROJECT_ROOT}/.devenv/profile/bin"
        "/usr/local/bin"
      )

      for dir in "${search_dirs[@]}"; do
        if [ -x "${dir}/${missing_cmd}" ]; then
          found_path="${dir}/${missing_cmd}"
          break
        fi
      done

      # Also try the user's interactive shell PATH (zsh likely has more)
      if [ -z "$found_path" ]; then
        found_path=$(zsh -ilc "command -v ${missing_cmd}" 2>/dev/null) || true
      fi

      if [ -n "$found_path" ]; then
        local found_dir
        found_dir=$(dirname "$found_path")
        fix_description="Prepended '${found_dir}' to PATH for '${missing_cmd}' (found at ${found_path})"

        # Redefine the test suite function to prepend PATH
        local suite_fn="test_suite_${name}"
        local original_body
        original_body=$(declare -f "$suite_fn" | tail -n +3 | head -n -1)

        eval "${suite_fn}() {
          export PATH=\"${found_dir}:\$PATH\"
          ${original_body}
        }"

        fixed=true
      else
        log WARN "env_fix: '${missing_cmd}' not found in any standard location"
        fix_description="Command '${missing_cmd}' not found — requires manual environment setup (e.g. devenv shell, nvm use, etc.)"
      fi
      ;;

    tool_shadow)
      # Specific fix: Python dotenv shadowing Node dotenv-cli
      local suite_fn="test_suite_${name}"
      local original_body
      original_body=$(declare -f "$suite_fn" | tail -n +3 | head -n -1)

      # Prepend node_modules/.bin to ensure Node's dotenv-cli wins
      if [ -d "${PROJECT_ROOT}/node_modules/.bin" ]; then
        fix_description="Prepended node_modules/.bin to PATH to resolve dotenv-cli/python-dotenv conflict"

        eval "${suite_fn}() {
          export PATH=\"${PROJECT_ROOT}/node_modules/.bin:\$PATH\"
          ${original_body}
        }"

        fixed=true
      else
        fix_description="Tool shadowing detected but no node_modules/.bin found"
      fi
      ;;

    db_missing)
      # Can't auto-fix — database setup is a manual prerequisite
      local db_name=""
      db_name=$(echo "$output" | grep -oE 'database "?[a-z_]+"?' | head -1 | tr -d '"')
      fix_description="Database '${db_name}' does not exist — requires manual setup (e.g. createdb, mix ecto.create, prisma migrate)"
      ;;

    env_missing)
      fix_description="Runtime environment not active — requires manual setup (e.g. devenv shell, nix develop)"
      ;;

    timeout)
      fix_description="Suite produced no output for ${SUITE_IDLE_TIMEOUT:-120}s (idle timeout) — likely hanging DB connection, stuck compilation, or missing runtime environment"
      ;;
  esac

  # Log the fix/skip for future reference
  local timestamp
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  {
    echo "[$timestamp] Suite: ${name} | Diagnosis: ${diagnosis} | Fixed: ${fixed}"
    echo "  ${fix_description}"
    if [ "$fixed" = true ]; then
      echo "  To make permanent, update .auto_claude.conf:"
      case "$diagnosis" in
        cmd_missing)
          echo "    Add to test_suite_${name}(): export PATH=\"<path>:\$PATH\""
          ;;
        tool_shadow)
          echo "    Add to test_suite_${name}(): export PATH=\"\${PROJECT_ROOT}/node_modules/.bin:\$PATH\""
          ;;
      esac
    fi
    echo ""
  } >> "$ENV_FIX_LOG"

  if [ "$fixed" = true ]; then
    log OK "env_fix: ${fix_description}"
    return 0
  else
    log WARN "env_fix: ${fix_description}"
    return 1
  fi
}

# ─── CI Check Infrastructure ─────────────────────────────────────────────────
#
# Projects define ci_check_*() and optional ci_fix_*() functions in
# .auto_claude.conf. If none are defined, _auto_discover_ci_checks reads
# package.json and synthesises them. The ci_checks phase runs each check,
# auto-fixes what it can, and sends unfixable issues to Claude.
#
# Convention:
#   ci_check_<name>()  — exit 0 = pass, non-zero = fail. Output goes to stdout.
#   ci_fix_<name>()    — auto-fix command. If absent, failures go to Claude.

_discover_ci_checks() {
  declare -F | awk '{print $3}' | grep '^ci_check_' || true
}

_has_ci_fix() {
  local name="$1"
  declare -F "ci_fix_${name}" &>/dev/null
}

# ─── CI Discovery Adapters ───────────────────────────────────────────────────
#
# Each adapter inspects a project manifest and synthesises ci_check_*/ci_fix_*
# functions if it recognises the project type. Adapters are tried in order by
# _run_discovery_adapters — the first one to populate checks wins.
#
# Port contract (unchanged):
#   ci_check_<n>()  — exit 0 = pass, non-zero = fail
#   ci_fix_<n>()    — auto-fix; absence means Claude-fixable
#
# To add a new adapter (e.g. pyproject.toml, Makefile), define a function
# named _ci_adapter_<name>() in .auto_claude.conf. It will be auto-discovered
# and run before the built-in adapters.

# Built-in adapter: package.json (npm/Node projects)
_ci_adapter_package_json() {
  local pkg="${PROJECT_ROOT}/package.json"
  [ -f "$pkg" ] || return 0

  local scripts
  scripts=$(jq -r '.scripts // {} | keys[]' "$pkg" 2>/dev/null) || return 0

  # Prettier / format check
  if echo "$scripts" | grep -qx 'prettier-check'; then
    eval 'ci_check_format() { cd "$PROJECT_ROOT" && npm run prettier-check 2>&1; }'
    if echo "$scripts" | grep -qx 'prettier-fix'; then
      eval 'ci_fix_format() { cd "$PROJECT_ROOT" && npm run prettier-fix 2>&1; }'
    else
      eval 'ci_fix_format() { cd "$PROJECT_ROOT" && npx prettier --write . 2>&1; }'
    fi
  elif echo "$scripts" | grep -qx 'format:check'; then
    eval 'ci_check_format() { cd "$PROJECT_ROOT" && npm run format:check 2>&1; }'
    if echo "$scripts" | grep -qx 'format'; then
      eval 'ci_fix_format() { cd "$PROJECT_ROOT" && npm run format 2>&1; }'
    fi
  fi

  # Lint
  if echo "$scripts" | grep -qx 'lint'; then
    eval 'ci_check_lint() { cd "$PROJECT_ROOT" && npm run lint 2>&1; }'
    if echo "$scripts" | grep -qx 'lint:fix'; then
      eval 'ci_fix_lint() { cd "$PROJECT_ROOT" && npm run lint:fix 2>&1; }'
    else
      eval 'ci_fix_lint() { cd "$PROJECT_ROOT" && npm run lint -- --fix 2>&1; }'
    fi
  fi

  # Type checking — explicit scripts first, then devDependencies fallback
  local tc_script=""
  for candidate in typecheck type-check tsc; do
    if echo "$scripts" | grep -qx "$candidate"; then
      tc_script="$candidate"
      break
    fi
  done

  if [ -n "$tc_script" ]; then
    eval "ci_check_types() { cd \"\$PROJECT_ROOT\" && npm run $tc_script 2>&1; }"
  elif jq -e '.devDependencies.typescript // .dependencies.typescript' "$pkg" &>/dev/null; then
    eval 'ci_check_types() { cd "$PROJECT_ROOT" && npx tsc --noEmit 2>&1; }'
  fi
  # No ci_fix_types — type errors go to Claude
}

# Dispatcher — runs conf-defined adapters first, then built-ins.
# Stops as soon as any adapter populates ci_check_* functions.
# Skips entirely if conf already defined ci_check_* functions directly.
#
# To register a custom adapter in .auto_claude.conf:
#   _ci_adapter_mystack() { ... define ci_check_*/ci_fix_* ... }
# It will be discovered automatically and run before the built-ins.
_auto_discover_ci_checks() {
  # Skip if conf defined ci_check_* functions directly
  if [ -n "$(_discover_ci_checks)" ]; then
    return 0
  fi

  # Discover and run conf-defined adapters first (_ci_adapter_* functions
  # other than the built-in _ci_adapter_package_json)
  local conf_adapters
  conf_adapters=$(declare -F | awk '{print $3}' | grep '^_ci_adapter_' | grep -v '_ci_adapter_package_json' || true)
  for adapter in $conf_adapters; do
    log INFO "Running CI adapter: ${adapter}..."
    "$adapter"
    if [ -n "$(_discover_ci_checks)" ]; then
      log INFO "CI checks populated by ${adapter}"
      return 0
    fi
  done

  # Fall back to built-in adapters
  log INFO "Running built-in CI adapter: package.json..."
  _ci_adapter_package_json
}

# ─── Default Hooks ───────────────────────────────────────────────────────────

# Default long-file finder — searches PROJECT_ROOT for source file extensions
# (configured via SOURCE_FILE_GLOBS), excluding tests, node_modules, and dist.
# Projects can override by defining project_find_long_files() in .auto_claude.conf.
_default_find_long_files() {
  local threshold="$1"

  # Build find -name arguments from SOURCE_FILE_GLOBS array
  local -a find_args=("$PROJECT_ROOT" "-type" "f" "(")
  local first=true
  for glob in "${SOURCE_FILE_GLOBS[@]}"; do
    if [ "$first" = true ]; then
      first=false
    else
      find_args+=("-o")
    fi
    find_args+=("-name" "$glob")
  done
  find_args+=(")"
    "!" "-name" "*.test.*"
    "!" "-name" "*.spec.*"
    "!" "-name" "test_*"
    "!" "-path" "*/node_modules/*"
    "!" "-path" "*/__pycache__/*"
    "!" "-path" "*/dist/*"
  )

  find "${find_args[@]}" -exec sh -c \
    'lines=$(wc -l < "$1"); if [ "$lines" -gt '"$threshold"' ]; then echo "$lines $1"; fi' _ {} \; \
    | sort -rn
}

# Dispatcher — uses project hook if defined, otherwise the default.
_find_long_files() {
  if declare -F project_find_long_files &>/dev/null; then
    project_find_long_files "$@"
  else
    _default_find_long_files "$@"
  fi
}

# Filter _find_long_files output to only include session-changed files.
# Without this, LOC enforcement loops forever on pre-existing long files
# that the pipeline didn't create — Claude correctly refuses to touch them,
# nothing changes, and the loop repeats until MAX_REFACTOR_ROUNDS.
_filter_to_changed() {
  local changed="$1"
  [ -z "$changed" ] && return
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    local fpath
    fpath="$(echo "$line" | awk '{print $2}')"
    local relpath="${fpath#"$PROJECT_ROOT"/}"
    if echo "$changed" | grep -qxF "$relpath"; then
      echo "$line"
    fi
  done
}

# ─── Phase Functions ─────────────────────────────────────────────────────────
#
# Authoring phases (plan, implement, test_fix) use run_claude (--continue)
# to share a single conversation with full context.
#
# Quality phases (skill_chain onward) use run_claude_fresh with a context pack
# for their first call, then run_claude (--continue) for subsequent calls
# within the same phase. Each quality phase starts a new conversation.

phase_plan() {
  if [ ! -f "$SPEC_FILE" ]; then
    log ERROR "Spec file not found: $SPEC_FILE"
    exit 1
  fi

  local spec_content
  spec_content="$(cat "$SPEC_FILE")"

  local ownership_context=""
  ownership_context=$(_build_ownership_context)

  local plan_prompt="You are working on the ${PROJECT_NAME} project.

${PLAN_CONTEXT:+${PLAN_CONTEXT}

}${ownership_context:+${ownership_context}

}Read this feature spec and create a detailed implementation plan:

---
${spec_content}
---

Your plan MUST:
1. List every file to create or modify
2. Ensure every change is testable
3. Identify what can be implemented in parallel vs what must be sequential

Output the plan as a numbered checklist."

  run_claude "$plan_prompt"
  log OK "Planning complete"
}

phase_decisions() {
  if [ "${EXPLAIN_PHASES:-true}" != "true" ]; then
    log INFO "Explainability disabled — skipping decisions manifest"
    return 0
  fi

  _ensure_explain_dir

  # Build artifact context if available
  local artifact_prompt=""
  if [ "$HAS_ARTIFACTS" = true ]; then
    local artifact_context
    artifact_context=$(_filter_artifacts_for_spec)
    if [ -n "$artifact_context" ]; then
      artifact_prompt="Before making decisions, review these structural facts about the entities you'll be working with:

${artifact_context}

Factor these into your decisions. If your planned approach conflicts with any structural fact, flag it as a risk.

"
    fi
  fi

  # Check for assumptions from previous deliverables (multi-deliverable support)
  local prior_assumptions=""
  if [ -f "$EXPLAIN_DIR/assumptions.json" ]; then
    local assumptions_content
    assumptions_content=$(cat "$EXPLAIN_DIR/assumptions.json" 2>/dev/null)
    if [ -n "$assumptions_content" ] && [ "$assumptions_content" != "[]" ] && [ "$assumptions_content" != "null" ]; then
      prior_assumptions="The following assumptions were made in earlier deliverables.
If your implementation depends on any of these, validate or challenge them:

\`\`\`json
${assumptions_content}
\`\`\`

"
    fi
  fi

  run_claude "${artifact_prompt}${prior_assumptions}Before implementing, analyse each deliverable and emit a decisions manifest.
For each deliverable, identify the key technical choices you'll make.

Output ONLY valid JSON (no markdown fences, no commentary before or after):
{
  \"deliverables\": [
    {
      \"id\": \"D1\",
      \"title\": \"...\",
      \"decisions\": [
        {
          \"id\": \"D1-001\",
          \"category\": \"data_source|pattern|module|dependency|api\",
          \"choice\": \"What you chose to do\",
          \"rationale\": \"Why you chose it\",
          \"assumption\": \"What must be true for this choice to be correct\",
          \"alternatives_considered\": [\"Other approach you rejected and why\"],
          \"risk\": \"What could go wrong if the assumption is wrong\"
        }
      ]
    }
  ]
}"

  # Parse and save
  local parsed
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      echo "$parsed" > "$EXPLAIN_DIR/decisions.json"
      _jq_update --argjson d "$parsed" '.semantic.decisions_manifest = $d'
      log OK "Decisions manifest saved to $EXPLAIN_DIR/decisions.json"
    else
      log WARN "Could not parse decisions manifest — continuing without it"
    fi
  else
    log WARN "Could not parse decisions manifest — continuing without it"
  fi

  # Optional human gate
  if [ "${DECISIONS_REVIEW:-false}" = "true" ]; then
    log INFO "DECISIONS_REVIEW enabled — review decisions at: $EXPLAIN_DIR/decisions.json"
    log INFO "Press Enter to continue, or Ctrl+C to abort..."
    read -r
  fi
}

phase_test_intent() {
  if [ "${TDD_ENABLED}" != "true" ]; then
    log INFO "TDD disabled — skipping test_intent phase"
    return 0
  fi

  if [ ! -f "$SPEC_FILE" ]; then
    log WARN "No spec file — skipping test_intent phase"
    return 0
  fi

  local spec_content
  spec_content="$(cat "$SPEC_FILE")"

  # Read decisions manifest if available
  local decisions_section=""
  local decisions_raw
  decisions_raw=$(_state_get '.semantic.decisions_manifest // empty')
  if [ -n "$decisions_raw" ] && [ "$decisions_raw" != "null" ]; then
    local formatted
    formatted=$(echo "$decisions_raw" | jq -r '
      [ (.deliverables // [])[] |
        .title + ":\n" +
        ([ (.decisions // [])[] | "  - " + .choice + " (" + .rationale + ")" ] | join("\n"))
      ] | join("\n\n")
    ' 2>/dev/null) || formatted=""
    if [ -n "$formatted" ]; then
      decisions_section="DECISIONS:
${formatted}

"
    fi
  fi

  run_claude "You have a plan and decisions. Before implementing, write TESTS ONLY that
encode the acceptance criteria from the spec.

SPEC:
${spec_content}

${decisions_section}Write tests for these layers: ${TDD_LAYERS}

Rules:
- Write ONLY test files — no implementation code
- Each test must have a descriptive name that states the intent
  (e.g. \"should return only NG122 recommendations when filtered to lung cancer guideline\")
- Each test must assert a specific expected behaviour
- Tests WILL fail — they test unimplemented code. That is correct.
- Do not introduce new testing patterns, unless the existing patterns
  cannot express the requirement. If you must deviate, add a comment
  explaining why.
- Match the test structure, assertion style, and file organization
  of existing tests in the project

For each layer in ${TDD_LAYERS}:
  unit — test individual functions/modules in isolation
  integration — test cross-module interactions (adapters, service composition)
  component — test React component behaviour (render + interact)
  e2e — test user workflows via Playwright (1-2 tests max, golden path only)

After writing all tests, output a JSON intent map.
Output ONLY valid JSON (no markdown fences, no commentary):
{
  \"intent_map\": [
    {
      \"test_file\": \"relative/path/to/test.ts\",
      \"layer\": \"unit|integration|component|e2e\",
      \"deliverable\": \"D1|D2|...\",
      \"intents\": [
        {
          \"test_name\": \"descriptive test name\",
          \"expected_behaviour\": \"1 sentence of what this test verifies\",
          \"assertion_type\": \"equality|contains|throws|renders|navigates\",
          \"key_assertion\": \"the core expect() or assertion line\"
        }
      ]
    }
  ]
}"

  # Parse the intent map from Claude's response
  local parsed=""
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      _jq_update --argjson m "$parsed" '.semantic.intent_map = ($m.intent_map // $m)'
      _ensure_explain_dir
      echo "$parsed" > "$EXPLAIN_DIR/intent_map.json"
      log OK "Intent map saved to state and $EXPLAIN_DIR/intent_map.json"
    else
      log WARN "Could not parse intent map — tests were written but no structured map available"
    fi
  else
    log WARN "Could not parse intent map — tests were written but no structured map available"
  fi

  # ── Red-phase verification: confirm new tests fail (expected before implementation) ──
  log INFO "Red-phase verification: confirming new tests fail..."
  local red_exit=0
  _run_all_suites || red_exit=$?

  if [ $red_exit -eq 0 ]; then
    log WARN "All tests pass before implementation. Either the feature already exists or tests are vacuous. Review intent_map."
    _jq_update --arg s "warning_all_pass" '.deterministic.tdd_status = $s'
  else
    # Check for syntax/compilation errors vs expected test failures
    if echo "$LAST_TEST_OUTPUT" | grep -qiE 'SyntaxError|ParseError|cannot find module|compilation failed'; then
      log WARN "Tests have syntax/parse errors — sending to Claude for one fix attempt"
      local syntax_output
      syntax_output=$(echo "$LAST_TEST_OUTPUT" | tail -n 200)
      run_claude "The test files you just wrote have syntax or compilation errors. Fix them.
Do NOT write implementation code — only fix the test file errors.

Errors:
\`\`\`
${syntax_output}
\`\`\`"
      _jq_update --arg s "red_fixed_syntax" '.deterministic.tdd_status = $s'
    else
      log OK "Red-phase verified: new tests fail as expected"
      _jq_update --arg s "red_verified" '.deterministic.tdd_status = $s'
    fi
  fi
}

phase_pattern_baseline() {
  if [ "${PATTERN_CONFORMANCE}" != "true" ]; then
    log INFO "Pattern conformance disabled — skipping pattern_baseline phase"
    return 0
  fi

  run_claude "Before implementing, catalogue the coding patterns in the areas you're about to change.
Read the files that are adjacent to or imported by the files listed in your plan.

For each pattern you observe, note:
- What area it governs (error handling, state management, test structure, etc.)
- Which files demonstrate it
- How strong it is: \"universal\" (every instance), \"strong\" (most instances),
  \"weak\" (a few instances), \"single\" (one instance — barely a pattern)

Also scan for existing PATTERN-DEVIATION comments — these are prior decisions
to intentionally deviate. Note them so you don't re-litigate them during implementation.

Output ONLY valid JSON (no markdown fences, no commentary):
{
  \"patterns\": [
    {
      \"id\": \"P001\",
      \"area\": \"description of what this pattern governs\",
      \"files_observed\": [\"file1.ts\", \"file2.ts\"],
      \"pattern\": \"description of the pattern\",
      \"strength\": \"universal|strong|weak|single\",
      \"occurrences\": 3
    }
  ],
  \"existing_deviations\": [
    {
      \"file\": \"path/to/file.ts\",
      \"line\": 42,
      \"comment\": \"the PATTERN-DEVIATION comment text\",
      \"pattern_area\": \"what pattern it deviates from\"
    }
  ]
}"

  local parsed=""
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      _jq_update --argjson p "$parsed" '.semantic.pattern_baseline = $p'
      _ensure_explain_dir
      echo "$parsed" > "$EXPLAIN_DIR/pattern_baseline.json"
      log OK "Pattern baseline saved to state and $EXPLAIN_DIR/pattern_baseline.json"
    else
      log WARN "Could not parse pattern baseline — conformance review will skip"
    fi
  else
    log WARN "Could not parse pattern baseline — conformance review will skip"
  fi
}

phase_implement() {
  local ownership_context=""
  ownership_context=$(_build_ownership_context)

  # If TDD is enabled and we have an intent map, use the TDD-aware prompt
  local intent_map=""
  intent_map=$(_state_get '.semantic.intent_map // empty')

  if [ "${TDD_ENABLED}" = "true" ] && [ -n "$intent_map" ] && [ "$intent_map" != "null" ]; then
    local formatted_intents
    formatted_intents=$(echo "$intent_map" | jq -r '
      [ .[] |
        "## " + .test_file + " (" + .layer + ")\n" +
        ([ .intents[]? |
          "- " + .test_name + ": " + .expected_behaviour
        ] | join("\n"))
      ] | join("\n\n")
    ' 2>/dev/null) || formatted_intents=""

    run_claude "${ownership_context:+${ownership_context}

}Tests have been written that encode the acceptance criteria. Your job is to
make them pass.

INTENT MAP (what the tests expect):
${formatted_intents}

Implement all changes now. Make every failing test pass.
Do NOT modify the test expectations — if a test seems wrong relative
to the spec, flag it as a comment but implement to the spec.
Commit nothing — just write the code."
  else
    # Original prompt — used when TDD_ENABLED=false or no intent map
    run_claude "${ownership_context:+${ownership_context}

}Execute the implementation plan you created in the previous step.
Implement all changes now. Follow the plan exactly.
Write tests alongside implementation.
Commit nothing — just write the code."
  fi

  log OK "Implementation complete"
}

phase_test_fix() {
  log INFO "Test-fix loop (max ${MAX_TEST_ITERATIONS} iterations)"

  # ── Pre-flight: diagnose environment issues before burning iterations ──
  # Run suites once, check for env issues, attempt fixes, skip unfixable.
  local preflight_exit=0
  _run_all_suites || preflight_exit=$?

  if [ $preflight_exit -eq 0 ]; then
    log OK "All tests pass on pre-flight"
    _update_test_results "pass" "0"
    _extract_coverage_map || true
    return 0
  fi

  # Diagnose each failed suite
  local env_fixed_any=false
  local all_env_skipped=true

  for name in $LAST_FAILED_SUITES; do
    local exit_code
    exit_code=$(_get_suite_exit "$name")
    local output
    output=$(_get_suite_output "$name")
    local diagnosis
    diagnosis=$(_diagnose_suite_failure "$name" "$exit_code" "$output")

    if [ "$diagnosis" = "code" ]; then
      all_env_skipped=false
      continue
    fi

    log WARN "Suite ${name}: diagnosed as '${diagnosis}' (not a code issue)"

    # Attempt auto-fix
    if _attempt_env_fix "$name" "$diagnosis" "$output"; then
      env_fixed_any=true
      log INFO "Re-running suite ${name} after env fix..."

      # Re-run just this suite to verify the fix
      local recheck_output recheck_exit=0
      recheck_output=$("test_suite_${name}" 2>&1) || recheck_exit=$?

      if [ $recheck_exit -eq 0 ]; then
        log OK "Suite ${name}: PASS after env fix"
        # Update tracking — move from failed to passed
        LAST_FAILED_SUITES="${LAST_FAILED_SUITES//${name} /}"
        LAST_PASSED_SUITES+="${name} "
      else
        # Fix didn't work — re-diagnose
        local re_diagnosis
        re_diagnosis=$(_diagnose_suite_failure "$name" "$recheck_exit" "$recheck_output")
        if [ "$re_diagnosis" != "code" ]; then
          log WARN "Suite ${name}: env fix did not resolve '${re_diagnosis}' — skipping suite"
          _ENV_SKIP_SUITES="${_ENV_SKIP_SUITES:+${_ENV_SKIP_SUITES},}${name}=${re_diagnosis}"
          LAST_FAILED_SUITES="${LAST_FAILED_SUITES//${name} /}"
          LAST_PASSED_SUITES+="${name} "
        else
          log INFO "Suite ${name}: env fix changed the error — now a code issue, will send to Claude"
          all_env_skipped=false
        fi
      fi
    else
      # Can't fix — skip this suite for the rest of the pipeline
      log WARN "Suite ${name}: cannot auto-fix '${diagnosis}' — skipping suite for this run"
      _ENV_SKIP_SUITES="${_ENV_SKIP_SUITES:+${_ENV_SKIP_SUITES},}${name}=${diagnosis}"
      LAST_FAILED_SUITES="${LAST_FAILED_SUITES//${name} /}"
      LAST_PASSED_SUITES+="${name} "
    fi
  done

  # If all failures were env-skipped, we're done
  if [ -z "$(echo "$LAST_FAILED_SUITES" | tr -d ' ')" ]; then
    local skip_count=0
    [ -n "$_ENV_SKIP_SUITES" ] && skip_count=$(echo "$_ENV_SKIP_SUITES" | tr ',' '\n' | grep -c '.')
    if [ "$skip_count" -gt 0 ]; then
      log WARN "All failed suites were environment issues (${skip_count} skipped). Continuing pipeline."
      log INFO "See ${ENV_FIX_LOG} for details and permanent fix instructions."
      _update_test_results "env_skip" "0"
    else
      log OK "All tests pass after env fixes"
      _update_test_results "pass" "0"
    fi
    _extract_coverage_map || true
    return 0
  fi

  # If we auto-fixed some suites, re-run all suites to get a clean baseline
  if [ "$env_fixed_any" = true ]; then
    log INFO "Re-running all suites after env fixes..."
    local rerun_exit=0
    _run_all_suites || rerun_exit=$?
    if [ $rerun_exit -eq 0 ]; then
      log OK "All tests pass after env fixes"
      _update_test_results "pass" "0"
      _extract_coverage_map || true
      return 0
    fi
  fi

  # ── Main test-fix loop (only for code failures) ──────────────────────
  local iteration=0

  if [ "${ESCALATION_ENABLED}" != "true" ]; then
    # Flat loop (backward compat — ESCALATION_ENABLED=false)
    while [ $iteration -lt $MAX_TEST_ITERATIONS ]; do
      iteration=$((iteration + 1))
      log INFO "Test iteration ${iteration}/${MAX_TEST_ITERATIONS}"

      if [ $iteration -gt 1 ]; then
        local test_exit=0
        _run_all_suites || test_exit=$?

        if [ $test_exit -eq 0 ]; then
          log OK "All tests pass on iteration ${iteration}"
          _update_test_results "pass" "$iteration"
          _extract_coverage_map || true
          return 0
        fi
      fi

      log WARN "Tests failed on iteration ${iteration}, asking Claude to fix..."

      local truncated_output
      truncated_output=$(echo "$LAST_TEST_OUTPUT" | tail -n 400)
      if [ "$(echo "$LAST_TEST_OUTPUT" | wc -l)" -gt 400 ]; then
        truncated_output="[...truncated to last 400 lines...]
${truncated_output}"
      fi

      run_claude "Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Passed suites: ${LAST_PASSED_SUITES}

Here is the test output:

\`\`\`
${truncated_output}
\`\`\`

Fix the failures in the failing suites. Do not change test expectations unless the test itself is wrong.
Fix the implementation to match the tests."
    done

    _update_test_results "fail" "$MAX_TEST_ITERATIONS"
    log ERROR "Tests still failing after ${MAX_TEST_ITERATIONS} iterations"
    return 1
  fi

  # Tiered escalation loop (ESCALATION_ENABLED=true)
  while [ $iteration -lt $MAX_TEST_ITERATIONS ]; do
    iteration=$((iteration + 1))
    local tier
    tier=$(_tier_for_iteration "$iteration")
    log INFO "Test iteration ${iteration}/${MAX_TEST_ITERATIONS} (tier ${tier})"

    # Re-run tests (skip on iteration 1 — pre-flight already ran)
    if [ $iteration -gt 1 ]; then
      local test_exit=0
      _run_all_suites || test_exit=$?

      if [ $test_exit -eq 0 ]; then
        log OK "All tests pass on iteration ${iteration}"
        _update_test_results "pass" "$iteration"
        _extract_coverage_map || true
        return 0
      fi
    fi

    log WARN "Tests failed on iteration ${iteration}, escalation tier ${tier}..."

    # Truncate test output (shared across all tiers)
    local truncated_output
    truncated_output=$(echo "$LAST_TEST_OUTPUT" | tail -n 400)
    if [ "$(echo "$LAST_TEST_OUTPUT" | wc -l)" -gt 400 ]; then
      truncated_output="[...truncated to last 400 lines...]
${truncated_output}"
    fi

    case "$tier" in
      1)
        # Tier 1: Tactical fix (current behavior + approach journal)
        local journal=""
        journal=$(_format_approach_journal)

        run_claude "${journal:+${journal}

}Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Passed suites: ${LAST_PASSED_SUITES}

Here is the test output:

\`\`\`
${truncated_output}
\`\`\`

Fix the failures in the failing suites. Do not change test expectations unless the test itself is wrong.
Fix the implementation to match the tests."

        _record_approach "$iteration"
        ;;

      2)
        # Tier 2: Re-anchored fix — re-inject spec + decisions + journal
        log INFO "Escalating to tier 2: re-anchoring with spec and decisions..."
        local reanchor_prompt
        reanchor_prompt=$(_build_reanchor_prompt "$truncated_output")
        run_claude "$reanchor_prompt"
        _record_approach "$iteration"
        ;;

      3)
        # Tier 3: Architectural consultation — fresh session
        log INFO "Escalating to tier 3: architectural consultation..."
        local consult_prompt
        consult_prompt=$(_build_consultation_prompt "$truncated_output")
        run_claude_fresh "$consult_prompt"

        # Parse alternatives JSON from fresh session
        local parsed=""
        if parsed=$(_extract_json_from_response); then
          if [ -n "$parsed" ]; then
            _jq_update --argjson a "$parsed" \
              '.deterministic.escalation.alternatives = ($a.alternatives // []) | .deterministic.escalation.diagnosis = ($a.diagnosis // null)'
            _ensure_explain_dir
            echo "$parsed" > "$EXPLAIN_DIR/alternatives.json"
            log OK "Consultation produced $(echo "$parsed" | jq '.alternatives | length') alternatives"
          else
            log WARN "Tier 3 parse failure — falling back to tactical fix"
            run_claude "Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Here is the test output:

\`\`\`
${truncated_output}
\`\`\`

Fix the failures."
          fi
        else
          log WARN "Tier 3 parse failure — falling back to tactical fix"
          run_claude "Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Here is the test output:

\`\`\`
${truncated_output}
\`\`\`

Fix the failures."
        fi

        _record_approach "$iteration"
        ;;

      4)
        # Tier 4: Human checkpoint — present alternatives, pause for input
        log INFO "Escalating to tier 4: human checkpoint..."
        local choice
        choice=$(_present_alternatives "$truncated_output")

        case "$choice" in
          [Aa]|[Bb]|[Cc])
            local alt_id
            alt_id=$(echo "$choice" | tr '[:lower:]' '[:upper:]')
            local alt_json
            alt_json=$(jq -r --arg id "$alt_id" \
              '.deterministic.escalation.alternatives[] | select(.id == $id)' \
              "$STATE_FILE" 2>/dev/null)
            if [ -n "$alt_json" ]; then
              _resume_with_alternative "$alt_json" "$truncated_output"
            else
              log WARN "Alternative ${alt_id} not found — retrying with tactical fix"
              run_claude "Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Here is the test output:
\`\`\`
${truncated_output}
\`\`\`
Fix the failures."
            fi
            _record_approach "$iteration"
            ;;
          [Rr])
            log INFO "Human chose retry — tactical fix"
            local journal=""
            journal=$(_format_approach_journal)
            run_claude "${journal:+${journal}

}Tests are failing. Failed suites: ${LAST_FAILED_SUITES}
Passed suites: ${LAST_PASSED_SUITES}

Here is the test output:

\`\`\`
${truncated_output}
\`\`\`

Fix the failures in the failing suites. Do not change test expectations unless the test itself is wrong.
Fix the implementation to match the tests."
            _record_approach "$iteration"
            ;;
          [Qq])
            log WARN "Human chose to abort pipeline"
            _update_test_results "escalation_abort" "$iteration"
            return 1
            ;;
          *)
            log WARN "Unrecognised choice '${choice}' — treating as abort"
            _update_test_results "escalation_abort" "$iteration"
            return 1
            ;;
        esac
        ;;
    esac

    # Track highest tier reached
    _jq_update --argjson t "$tier" \
      '.deterministic.escalation.tier_reached = ([$t, (.deterministic.escalation.tier_reached // 0)] | max)'
  done

  _update_test_results "fail" "$MAX_TEST_ITERATIONS"
  log ERROR "Tests still failing after ${MAX_TEST_ITERATIONS} iterations"
  return 1
}

phase_ci_checks() {
  local checks
  checks=$(_discover_ci_checks)

  if [ -z "$checks" ]; then
    log OK "No CI checks configured — skipping"
    _jq_update '.deterministic.ci_checks_results.final_status = "skipped"'
    return 0
  fi

  # Record discovered checks in state
  local check_names=()
  for check_fn in $checks; do
    check_names+=("${check_fn#ci_check_}")
  done
  _jq_update --argjson names "$(printf '%s\n' "${check_names[@]}" | jq -R . | jq -s .)" \
    '.deterministic.ci_checks_results.checks_discovered = $names'

  log INFO "CI checks (max ${MAX_CI_ITERATIONS} iterations)"

  local ci_tmp_dir
  ci_tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ac_ci_checks.XXXXXX")
  trap "rm -rf '$ci_tmp_dir'" RETURN

  local iteration=0
  while [ $iteration -lt $MAX_CI_ITERATIONS ]; do
    iteration=$((iteration + 1))
    log INFO "CI check iteration ${iteration}/${MAX_CI_ITERATIONS}"

    # ── Run all checks ──────────────────────────────────────────────────
    local all_passed=true
    local auto_fixable=""
    local claude_fixable=""

    for check_fn in $checks; do
      local name="${check_fn#ci_check_}"
      log INFO "Running check: ${name}..."
      local exit_code=0
      "$check_fn" > "${ci_tmp_dir}/${name}.out" 2>&1 || exit_code=$?

      if [ $exit_code -ne 0 ]; then
        all_passed=false
        if _has_ci_fix "$name"; then
          auto_fixable+="${name} "
        else
          claude_fixable+="${name} "
        fi
        log WARN "Check ${name}: FAIL"
      else
        log OK "Check ${name}: PASS"
      fi
    done

    if [ "$all_passed" = true ]; then
      log OK "All CI checks pass on iteration ${iteration}"
      _jq_update --arg iters "$iteration" \
        '.deterministic.ci_checks_results.final_status = "pass" |
         .deterministic.ci_checks_results.iterations_needed = ($iters | tonumber)'
      return 0
    fi

    local any_fixes_applied=false

    # ── Auto-fix ────────────────────────────────────────────────────────
    for name in $auto_fixable; do
      log INFO "Auto-fixing: ${name}..."
      "ci_fix_${name}" > /dev/null 2>&1 || true
      any_fixes_applied=true

      # Re-check to confirm the fix worked
      local recheck_exit=0
      "ci_check_${name}" > "${ci_tmp_dir}/${name}.out" 2>&1 || recheck_exit=$?
      if [ $recheck_exit -ne 0 ]; then
        log WARN "Auto-fix for ${name} did not fully resolve — promoting to Claude"
        claude_fixable+="${name} "
      else
        log OK "Auto-fix resolved: ${name}"
        _jq_update --arg n "$name" \
          '.deterministic.ci_checks_results.auto_fixed += [$n] | .deterministic.ci_checks_results.auto_fixed |= unique'
      fi
    done

    # ── Claude-fix ──────────────────────────────────────────────────────
    if [ -n "${claude_fixable}" ]; then
      local prompt
      prompt="The following CI checks are failing after auto-fixes have been applied:\n\n"
      for name in $claude_fixable; do
        local truncated
        truncated=$(tail -n 200 "${ci_tmp_dir}/${name}.out" 2>/dev/null || echo "(no output)")
        prompt+="### ${name}\n\`\`\`\n${truncated}\n\`\`\`\n\n"
      done
      prompt+="Fix these issues in the source code. Do not change test expectations unless a test is genuinely wrong."

      run_claude "$prompt"
      any_fixes_applied=true

      # Record Claude-fixed checks
      for name in $claude_fixable; do
        _jq_update --arg n "$name" \
          '.deterministic.ci_checks_results.claude_fixed += [$n] | .deterministic.ci_checks_results.claude_fixed |= unique'
      done
    fi

    # ── Re-run tests after any fixes ────────────────────────────────────
    if [ "$any_fixes_applied" = true ]; then
      log INFO "Re-running tests after CI fixes..."
      if ! _run_all_suites; then
        log WARN "CI fixes broke tests — asking Claude to fix..."
        local truncated_test_output
        truncated_test_output=$(echo "$LAST_TEST_OUTPUT" | tail -n 400)
        run_claude "Your CI check fixes broke tests. Failed suites: ${LAST_FAILED_SUITES}

\`\`\`
${truncated_test_output}
\`\`\`

Fix the test failures without reverting the CI fixes. Adjust the implementation so both CI checks and tests pass."
      fi
    fi
  done

  _jq_update --arg iters "$MAX_CI_ITERATIONS" \
    '.deterministic.ci_checks_results.final_status = "fail" |
     .deterministic.ci_checks_results.iterations_needed = ($iters | tonumber)'
  log ERROR "CI checks still failing after ${MAX_CI_ITERATIONS} iterations"
  return 1
}

# ─── Quality Phase Functions ─────────────────────────────────────────────────
# Each uses run_claude_fresh for its first call (with context pack), then
# run_claude (--continue) for subsequent calls within the same phase.

phase_impact() {
  if [ "${EXPLAIN_PHASES:-true}" != "true" ]; then
    log INFO "Explainability disabled — skipping impact assessment"
    return 0
  fi

  _ensure_explain_dir

  if [ "$HAS_ARTIFACTS" = true ]; then
    # Step A: Deterministic blast radius computation
    log INFO "Computing blast radius from recovery artifacts..."
    if _compute_blast_radius; then
      if [ ! -f "$EXPLAIN_DIR/blast_radius.json" ]; then
        log WARN "Blast radius computation produced no output — falling back to LLM-only"
        _impact_llm_only
        return 0
      fi

      # Step B: Classification gate
      local classification
      classification=$(jq -r '.classification // "leaf"' "$EXPLAIN_DIR/blast_radius.json" 2>/dev/null)
      log INFO "Change classification: ${classification}"

      if [ "$classification" = "leaf" ]; then
        log OK "Leaf change — skipping impact narrative"
        _jq_update '.semantic.impact_classification = "leaf"'
        return 0
      fi

      # Step C: Narrative synthesis for boundary/core
      log INFO "Generating impact narrative (${classification} change)..."
      local blast_content
      blast_content=$(cat "$EXPLAIN_DIR/blast_radius.json")

      local context
      context=$(_build_context_pack "skill_chain")

      run_claude_fresh "${context}

---

You are reviewing the blast radius of a code change.
The following impact data was computed by analysing the codebase's dependency graphs, data ownership, event contracts, and invariants.

\`\`\`json
${blast_content}
\`\`\`

Write a concise impact assessment:
1. Which downstream systems or workflows could be affected?
2. Are there any invariants this change could violate?
3. Are there view/table assumptions that need verification?
4. What specific tests or manual checks should be added?

Keep it under 500 words. Be specific — cite the evidence from the blast radius data."

      echo "$LAST_RESPONSE_TEXT" > "$EXPLAIN_DIR/impact_assessment.md"
      _jq_update --arg c "$classification" '.semantic.impact_classification = $c'
      log OK "Impact assessment saved to $EXPLAIN_DIR/impact_assessment.md"

      # Core classification gate
      if [ "$classification" = "core" ]; then
        log WARN "CORE change detected — review impact at: $EXPLAIN_DIR/impact_assessment.md"
        log INFO "Press Enter to continue, or Ctrl+C to abort..."
        read -r
      fi
    else
      log WARN "blast_radius.py failed — falling back to LLM-only"
      _impact_llm_only
    fi
  else
    _impact_llm_only
  fi
}

_compute_blast_radius() {
  local changed_files
  changed_files=$(_state_get '.deterministic.files_changed[]' 2>/dev/null || true)

  if [ -z "$changed_files" ]; then
    log WARN "No changed files in state — skipping blast radius"
    return 1
  fi

  # Write changed files to a temp file for blast_radius.py
  local tmpfile
  tmpfile=$(mktemp)
  echo "$changed_files" > "$tmpfile"

  local args=()
  args+=(--changed-files "$tmpfile")
  args+=(--output "$EXPLAIN_DIR/blast_radius.json")

  # Add each artifact file if it exists
  [ -f "$ARTIFACTS_DIR/system_graph.json" ] && args+=(--system-graph "$ARTIFACTS_DIR/system_graph.json")
  [ -f "$ARTIFACTS_DIR/behaviour_graph.json" ] && args+=(--behaviour-graph "$ARTIFACTS_DIR/behaviour_graph.json")
  [ -f "$ARTIFACTS_DIR/data_ownership.json" ] && args+=(--data-ownership "$ARTIFACTS_DIR/data_ownership.json")
  [ -f "$ARTIFACTS_DIR/event_contracts.json" ] && args+=(--event-contracts "$ARTIFACTS_DIR/event_contracts.json")
  [ -f "$ARTIFACTS_DIR/failure_topology.json" ] && args+=(--failure-topology "$ARTIFACTS_DIR/failure_topology.json")
  [ -f "$ARTIFACTS_DIR/invariants.json" ] && args+=(--invariants "$ARTIFACTS_DIR/invariants.json")
  [ -f "$ARTIFACTS_DIR/test_coverage_topology.json" ] && args+=(--test-coverage "$ARTIFACTS_DIR/test_coverage_topology.json")

  python3 "$SCRIPT_DIR/blast_radius.py" "${args[@]}" 2>&1 | tee -a "$LOG_FILE"
  local rc=${PIPESTATUS[0]}

  rm -f "$tmpfile"
  return $rc
}

_impact_llm_only() {
  log INFO "Running LLM-only impact assessment (no recovery artifacts)"

  local context
  context=$(_build_context_pack "skill_chain")

  local changed_files
  changed_files=$(_state_get '.deterministic.files_changed[]' 2>/dev/null || echo "(unknown)")

  run_claude_fresh "${context}

---

No recovery artifacts available — blast radius analysis is LLM-only.
Consider running recovery analysis for this project for deterministic impact assessment.

List the tables/entities this code reads and writes. For each, consider:
1. Is it a table or a view? If a view, what does it filter?
2. Do other parts of the system depend on it?
3. Are there event contracts that trigger on changes to it?
4. What are the downstream effects of this change?

These files were changed:
${changed_files}

Output a brief impact assessment (under 300 words)."

  _ensure_explain_dir
  echo "$LAST_RESPONSE_TEXT" > "$EXPLAIN_DIR/impact_assessment.md"
  _jq_update '.semantic.impact_classification = "leaf_llm_only"'
  log OK "LLM-only impact assessment saved"
}

phase_skill_chain() {
  local context
  context=$(_build_context_pack "skill_chain")

  # Build test audit context for the reviewer
  local test_audit_prompt=""
  local audit_status
  audit_status=$(_state_get '.semantic.test_audit.status // "none"')
  if [ "$audit_status" = "audited" ]; then
    local del add net deleted_blocks_text
    del=$(_state_get '.semantic.test_audit.deleted_assertions // 0')
    add=$(_state_get '.semantic.test_audit.added_assertions // 0')
    net=$(_state_get '.semantic.test_audit.net // 0')
    deleted_blocks_text=$(_state_get '(.semantic.test_audit.deleted_blocks // []) | map("  - " + .) | join("\n")')

    if [ "$net" -lt 0 ]; then
      test_audit_prompt="
- TEST DELETION AUDIT (${del} assertions deleted, ${add} added, net: ${net}):
${deleted_blocks_text:+  Deleted test blocks:
${deleted_blocks_text}
}  For EACH deleted it()/expect() in test files, verify:
  1. Does the tested scenario still exist under a different name/entity? If yes → UPDATE the test to the new context, do NOT delete it.
  2. If source code was changed (e.g. type signature, error format) → verify the test assertion was updated to match, not just deleted.
  3. Deep.equal/toEqual assertions for scoring, eligibility, or result shape should be adapted to replacement entities, not removed.
  4. Only delete a test if the tested code path has been removed with NO replacement.
  Restore any unjustified deletions by updating them to the new context."
    fi
  fi

  # Coding review — first call starts fresh session with context pack
  log INFO "Running coding review..."
  local no_rerun_tests="IMPORTANT: Tests have already passed in the test_fix phase. Do NOT re-run tests (mix test, npm test, etc.). Only review the code and make changes to the source files. If you make changes that could break tests, note what should be re-tested but do not run them yourself."

  run_claude_fresh "${context}

---

You are reviewing code changes in the ${PROJECT_NAME} project.

${no_rerun_tests}

Review all code in the changed files for:
- Unnecessary complexity or abstraction
- Missing error handling at system boundaries
- Inconsistent naming or patterns compared to existing codebase
${test_audit_prompt}
${REVIEW_EXTRAS:+${REVIEW_EXTRAS}
}Fix any issues you find."

  # Pattern conformance — continues the skill_chain conversation
  if [ "${PATTERN_CONFORMANCE}" = "true" ]; then
    log INFO "Running pattern conformance..."
    _run_pattern_conformance
    _extract_conformance_findings
  fi

  # Security check — continues the skill_chain conversation
  log INFO "Running security check..."
  run_claude "${no_rerun_tests}

Review all code in the changed files for security issues:
- No secrets or API keys in source code
- Input validation at system boundaries (user input, external APIs)
- No XSS in rendered content
- Proper auth checks on routes
${SECURITY_EXTRAS:+${SECURITY_EXTRAS}
}Fix any issues you find."

  # Simplification — continues the skill_chain conversation
  log INFO "Running simplification..."
  run_claude "${no_rerun_tests}

Review all code in the changed files for simplification:
- Remove dead code, unused imports, commented-out blocks
- Replace over-engineered abstractions with simpler alternatives
- Ensure no file exceeds ${MAX_LOC} lines (excluding tests)
- If a file exceeds ${MAX_LOC} lines, split it into focused modules
Fix any issues you find."

  # Extract structured findings so downstream phases (especially final) can
  # surface specific issues, security assessment, and simplifications made.
  _extract_skill_chain_findings

  log OK "Skill chain complete"
}

phase_loc_enforcement() {
  log INFO "LOC enforcement (max ${MAX_LOC} LOC, max ${MAX_REFACTOR_ROUNDS} rounds)"

  local changed_files
  changed_files="$(get_changed_files)"

  if [ -z "$changed_files" ]; then
    log OK "No changed files — skipping LOC enforcement"
    return 0
  fi

  local context
  context=$(_build_context_pack "loc_enforcement")

  local round=0
  local prev_long_files=""
  local first_call=true

  while [ $round -lt $MAX_REFACTOR_ROUNDS ]; do
    round=$((round + 1))
    local long_files
    long_files="$(_find_long_files "$MAX_LOC" | _filter_to_changed "$changed_files")"

    if [ -z "$long_files" ]; then
      log OK "All session files within ${MAX_LOC} LOC limit"
      return 0
    fi

    # Stale-detection: if the list is identical to last round, Claude couldn't
    # (or chose not to) split these files. Break instead of looping forever.
    if [ "$long_files" = "$prev_long_files" ]; then
      log WARN "No progress since last round — these files could not be split further:"
      echo "$long_files" | while IFS= read -r line; do
        log WARN "  $line"
      done
      log WARN "Continuing to next phase."
      return 0
    fi
    prev_long_files="$long_files"

    log WARN "Session files exceeding ${MAX_LOC} LOC (round ${round}):"
    echo "$long_files" | while IFS= read -r line; do
      log WARN "  $line"
    done

    local refactor_prompt="The following files exceed ${MAX_LOC} lines of code:

${long_files}

Refactor each file:
1. Extract logical units into separate modules
2. Maintain all existing exports (no breaking changes)
3. Update imports in dependent files
4. Ensure tests still pass after refactoring

If a file cannot be meaningfully split further (e.g. it is a thin orchestrator with re-exports), explain why and move on."

    if [ "$first_call" = true ]; then
      run_claude_fresh "${context}

---

${refactor_prompt}"
      first_call=false
    else
      run_claude "$refactor_prompt"
    fi

    # Smoke test after refactor
    if ! _run_all_suites; then
      log ERROR "Tests broke during LOC refactoring on round ${round}"
      run_claude "The refactoring broke tests. Fix the failures without reverting the split — adjust imports and references."
    fi

    # Refresh changed files — refactoring creates new files
    changed_files="$(get_changed_files)"
  done

  log WARN "LOC enforcement incomplete after ${MAX_REFACTOR_ROUNDS} rounds"
  return 1
}

# Check if any file in a newline-separated list matches a glob pattern.
# Handles JSON array globs (["*.tsx", "*.jsx"]) and bare string globs ("*.tsx").
# Uses bash extglob and shopt globstar-style matching.
# Returns 0 if any file matches, 1 otherwise.
_files_match_glob() {
  local globs_raw="$1"
  local changed_files="$2"

  # Parse globs — handle JSON array ["*.tsx", "*.jsx"] or bare string
  local -a globs=()
  if [[ "$globs_raw" == \[* ]]; then
    # JSON array — extract quoted strings
    while IFS= read -r g; do
      globs+=("$g")
    done < <(echo "$globs_raw" | tr -d '[]' | tr ',' '\n' | sed 's/^[[:space:]]*"//; s/"[[:space:]]*$//' | grep -v '^$')
  elif [ -n "$globs_raw" ]; then
    globs+=("$globs_raw")
  fi

  # No globs defined — rule has no file restriction
  if [ ${#globs[@]} -eq 0 ]; then
    return 0
  fi

  # Check each changed file against each glob
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    for glob in "${globs[@]}"; do
      # Convert glob to regex: ** → .*, * → [^/]*, . → \., rest literal
      local regex
      regex=$(echo "$glob" | sed \
        -e 's/\./\\./g' \
        -e 's/\*\*/.*/g' \
        -e 's/\([^.]\)\*/\1[^\/]*/g' \
        -e 's/^\*/[^\/]*/g')
      if [[ "$file" =~ ^${regex}$ ]]; then
        return 0
      fi
    done
  done <<< "$changed_files"

  return 1
}

# Extract a YAML frontmatter field value from an .mdc file.
# Usage: _mdc_field "fieldname" < file.mdc
_mdc_field() {
  local field="$1"
  # Read between first and second ---, extract the field
  sed -n '/^---$/,/^---$/p' | grep "^${field}:" | sed "s/^${field}:[[:space:]]*//"
}

# Load repo-specific review rules from .cursor/BUGBOT.md and .cursor/rules/**/*.mdc
# .mdc files are filtered by their frontmatter globs against the changed files list.
# alwaysApply: true rules are always included regardless of globs.
# Returns the combined rules as a string, or empty if none found.
_load_repo_review_rules() {
  local changed_files="$1"
  local rules=""
  local found_any=false

  # Load BUGBOT.md if present (always applies — it's repo-wide)
  if [ -f "${PROJECT_ROOT}/.cursor/BUGBOT.md" ]; then
    rules+="
### Repo Review Rules (from .cursor/BUGBOT.md)

$(cat "${PROJECT_ROOT}/.cursor/BUGBOT.md")
"
    log INFO "Loaded repo review rules from .cursor/BUGBOT.md"
    found_any=true
  fi

  # Load .cursor/rules/**/*.mdc files — filter by globs and alwaysApply
  local mdc_files
  mdc_files=$(find "${PROJECT_ROOT}/.cursor/rules" -name "*.mdc" -type f 2>/dev/null || true)

  if [ -n "$mdc_files" ]; then
    local included_count=0
    local skipped_count=0
    local org_rules=""

    while IFS= read -r mdc_file; do
      local relative_path="${mdc_file#"${PROJECT_ROOT}/"}"

      # Extract frontmatter fields
      local always_apply globs_raw
      always_apply=$(cat "$mdc_file" | _mdc_field "alwaysApply")
      globs_raw=$(cat "$mdc_file" | _mdc_field "globs")

      # Determine if this rule should be included
      local include=false
      if [ "$always_apply" = "true" ]; then
        include=true
      elif _files_match_glob "$globs_raw" "$changed_files"; then
        include=true
      fi

      if [ "$include" = true ]; then
        # Strip YAML frontmatter, keep body
        local body
        # awk replaces `sed '1{/^$/d}'` — BSD/macOS sed rejects that brace
        # form. This drops the first line only if it's blank, portably
        # across GNU (Linux/CI) and BSD (macOS).
        body=$(sed -n '/^---$/,/^---$/!p' "$mdc_file" | awk 'NR==1 && /^$/ { next } { print }')
        if [ -n "$body" ]; then
          org_rules+="
#### ${relative_path}
${body}
"
          log INFO "Loaded review rule: ${relative_path} ($([ "$always_apply" = "true" ] && echo "alwaysApply" || echo "glob match"))"
          included_count=$((included_count + 1))
        fi
      else
        log INFO "Skipped review rule: ${relative_path} (no glob match)"
        skipped_count=$((skipped_count + 1))
      fi
    done <<< "$mdc_files"

    if [ $included_count -gt 0 ]; then
      rules+="
### Org/Team Review Rules (from .cursor/rules/)
${org_rules}"
      found_any=true
    fi
    log INFO "Review rules: ${included_count} loaded, ${skipped_count} skipped (glob mismatch)"
  fi

  if [ "$found_any" = false ]; then
    log INFO "No repo review rules found (.cursor/BUGBOT.md or .cursor/rules/**/*.mdc)"
  fi

  echo "$rules"
}

phase_fresh_review() {
  local changed_files
  changed_files="$(get_changed_files)"

  if [ -z "$changed_files" ]; then
    log WARN "No changed files detected for review"
    return 0
  fi

  local context
  context=$(_build_context_pack "fresh_review")

  local repo_review_rules
  repo_review_rules=$(_load_repo_review_rules "$changed_files")

  # Fresh context — the reviewer has never seen this code and evaluates it cold.
  # Context pack deliberately excludes plan_intent to avoid anchoring bias.
  run_claude_fresh "${context}

---

You are reviewing code changes in the ${PROJECT_NAME} project. You did NOT write this code. Evaluate it objectively.

IMPORTANT: Tests have already passed in the test_fix phase. Do NOT re-run tests (mix test, npm test, etc.). Only review the code and fix source files. If you make changes that could break tests, note what should be re-tested but do not run them yourself.

${FRESH_REVIEW_PREAMBLE:+${FRESH_REVIEW_PREAMBLE}

}${repo_review_rules:+${repo_review_rules}

}These files were changed:
${changed_files}

Review each changed file for:

${FRESH_REVIEW_EXTRAS:+${FRESH_REVIEW_EXTRAS}

}1. **Correctness**
   - Do the implementations match their test expectations?
   - Are there edge cases not covered?
   - Are error paths handled?

2. **Code quality**
   - Files over ${MAX_LOC} LOC?
   - Unnecessary abstractions?
   - Dead code or unused imports?
   - Naming consistency with the rest of the codebase?

3. **Security**
   - Hardcoded secrets?
   - Injection risks in queries?
   - Unvalidated user input?

Output a review in this format:

## Fresh-Context Review

### Issues Found (fix required)
- [file:line] description

### Warnings (consider fixing)
- [file:line] description

### Approved
- [list of files that pass review]

If issues are found, fix them now."

  # Extract review findings into state so downstream phases (especially final)
  # can surface warnings, limitations, and follow-up items. This continues the
  # fresh_review session, so Claude has full context of what it found.
  _extract_review_findings

  log OK "Fresh-context review complete"
}

phase_doc_update() {
  local changed_files
  changed_files="$(get_changed_files)"

  if [ -z "$changed_files" ]; then
    log WARN "No changed files detected — skipping doc update"
    return 0
  fi

  local context
  context=$(_build_context_pack "doc_update")

  local doc_body
  if [ -n "${DOC_UPDATE_CONTEXT:-}" ]; then
    doc_body="$DOC_UPDATE_CONTEXT"
  else
    doc_body="Update any documentation that references the changed files. Fix stale file paths, type signatures, and status tables."
  fi

  run_claude_fresh "${context}

---

You have finished implementing and reviewing code changes. Now update documentation to reflect what changed.

These files were modified in this session:
${changed_files}

${doc_body}"

  # Extract which docs were updated so the final summary can report them.
  _extract_doc_update_summary

  log OK "Documentation update complete"
}

phase_final() {
  local context
  context=$(_build_context_pack "final")

  run_claude_fresh "${context}

---

Summarise what was implemented in this session.
Output:
1. List of files created or modified
2. Step-by-step instructions for manually testing the feature from a user's perspective
3. Any known limitations or follow-up work needed"

  # ─── Auto-commit ──────────────────────────────────────────────────────────
  # Stage all files changed during this pipeline run and commit them.
  # Skips if no git repo, no changes, or tests didn't pass.
  if [ "$HAS_GIT" = true ]; then
    local test_status
    test_status=$(_state_get '.deterministic.test_results.final_status // "unknown"')
    if [ "$test_status" != "pass" ]; then
      log WARN "Skipping auto-commit: tests status is '${test_status}', not 'pass'"
    else
      cd "$PROJECT_ROOT"
      local changed_files
      changed_files=$(get_changed_files)
      if [ -z "$changed_files" ]; then
        log WARN "Skipping auto-commit: no changed files detected"
      else
        # Stage changed files, excluding auto_claude runtime artifacts and gitignored paths.
        # Uses sed instead of grep -v to avoid exit 1 on no match (bash 3.2 errtrace).
        # git check-ignore exits 0=ignored, 1=not-ignored, 128=error — we only want to
        # stage files where it exits 1 (not ignored). Exit 128 (bad path, not in repo)
        # must not propagate into the ERR trap, so we use a local var to capture it.
        echo "$changed_files" | sed '/\.auto_claude/d; /\.claude\/plans\//d' | while IFS= read -r f; do
          [ -n "$f" ] || continue
          [ -f "$PROJECT_ROOT/$f" ] || continue
          local _ci_rc=0
          git check-ignore -q "$PROJECT_ROOT/$f" 2>/dev/null || _ci_rc=$?
          # 0 = gitignored (skip), 1 = not ignored (stage it), 128 = error (skip safely)
          [ "$_ci_rc" -eq 1 ] && git add "$PROJECT_ROOT/$f" || true
        done

        # Build commit message from state
        local plan_intent impl_summary spec_basename branch_name
        plan_intent=$(_state_get '.semantic.plan_intent // "Pipeline implementation"')
        impl_summary=$(_state_get '.semantic.implementation_summary // empty')
        spec_basename=$(basename "$SPEC_FILE" .md 2>/dev/null || echo "spec")
        branch_name=$(git branch --show-current 2>/dev/null || echo "unknown")

        # Truncate plan_intent to first sentence for the subject line
        local subject
        subject=$(echo "$plan_intent" | sed 's/\. .*//' | cut -c1-72)

        local body=""
        if [ -n "$impl_summary" ] && [ "$impl_summary" != "null" ]; then
          body="$impl_summary"
        fi

        local commit_msg
        if [ -n "$body" ]; then
          commit_msg=$(printf '%s\n\n%s\n\nSpec: %s' \
            "$subject" "$body" "$spec_basename")
        else
          commit_msg=$(printf '%s\n\nSpec: %s' \
            "$subject" "$spec_basename")
        fi

        if git diff --cached --quiet 2>/dev/null; then
          log WARN "Skipping auto-commit: nothing staged after filtering"
        else
          if git commit -m "$commit_msg" --no-verify 2>&1 | tee -a "$LOG_FILE"; then
            local new_sha
            new_sha=$(git rev-parse --short HEAD 2>/dev/null)
            log OK "Committed: ${new_sha} on branch ${branch_name}"
          else
            log WARN "git commit failed — changes remain staged but uncommitted"
          fi
        fi
      fi
    fi
  fi

  log OK "Pipeline complete"
}

# ─── Source Project Config ───────────────────────────────────────────────────

CONF_FILE="${PROJECT_ROOT}/.auto_claude.conf"
if [ -f "$CONF_FILE" ]; then
  # shellcheck source=/dev/null
  source "$CONF_FILE"
else
  echo "ERROR: No .auto_claude.conf found in ${PROJECT_ROOT}" >&2
  echo "Create one with at least one test_suite_*() function." >&2
  exit 1
fi

# ─── Artifact Detection ───────────────────────────────────────────────────────
_detect_artifacts

# ─── Opinionated Mode Resolution ────────────────────────────────────────────
# CLI flag takes precedence over conf. If neither set, defaults to false.
#
# OFF: standards injected as advisory observations — Claude notes what it would
#      have applied and why, but does not enforce them. You see the delta.
# ON:  standards injected as requirements — Claude applies them, not suggests.
#
# Think of it as warning mode vs error mode. Same rules, different enforcement.

[ "$_CLI_OPINIONATED" = true ] && OPINIONATED=true

# The four principles — shared between both modes, framing differs.
_OPINIONATED_PRINCIPLES='''1. **Discriminated unions over optional fields** — when a type has distinct
   states, use tagged unions so each variant carries exactly the fields it needs.
   Make impossible states impossible at compile time.

2. **Ports and adapters at natural seams** — where the code crosses a boundary
   (external service, CLI tool, config system), define a port (interface/function
   convention) and keep adapters separate. The core should not know which adapter
   is wired in.

3. **Prefer simpler by default** — when two approaches are valid, default to the
   less complex one. Add abstraction only when the simpler option demonstrably
   cannot serve the need.

4. **Defer to existing patterns** — examine the codebase first. Follow existing
   patterns unless the requirement genuinely cannot be served by them.'''

if [ "$OPINIONATED" = true ]; then
  _OPINIONATED_FRAGMENT="## Architectural Standards (enforced)

The following principles are requirements for this run. Examine existing codebase
patterns first and defer to them — but where they conflict with these standards,
apply the standards and note the departure.

${_OPINIONATED_PRINCIPLES}"

  # Prepend to any project-defined values so conf can still extend them
  PLAN_CONTEXT="${_OPINIONATED_FRAGMENT}${PLAN_CONTEXT:+

${PLAN_CONTEXT}}"
  REVIEW_EXTRAS="${_OPINIONATED_FRAGMENT}${REVIEW_EXTRAS:+

${REVIEW_EXTRAS}}"
  FRESH_REVIEW_PREAMBLE="${_OPINIONATED_FRAGMENT}${FRESH_REVIEW_PREAMBLE:+

${FRESH_REVIEW_PREAMBLE}}"
  log INFO "Opinionated mode: ON — architectural standards enforced in phase prompts"
else
  _OPINIONATED_FRAGMENT="## Architectural Observations (advisory)

You are NOT required to apply the following principles. However, where you notice
opportunities or violations, surface them as named observations in your review
output — labelled as advisory, not blocking. This gives the engineer visibility
into what opinionated mode would have enforced.

${_OPINIONATED_PRINCIPLES}"

  # Advisory mode — inject into review phases only, not plan/implement
  REVIEW_EXTRAS="${_OPINIONATED_FRAGMENT}${REVIEW_EXTRAS:+

${REVIEW_EXTRAS}}"
  FRESH_REVIEW_PREAMBLE="${_OPINIONATED_FRAGMENT}${FRESH_REVIEW_PREAMBLE:+

${FRESH_REVIEW_PREAMBLE}}"
  log INFO "Opinionated mode: OFF — architectural standards surfaced as advisory observations in review phases"
fi


# ─── Spec-Level Suite Override ────────────────────────────────────────────
# A spec can declare which test suites to run via a header comment:
#   # auto_claude: test_suites=build,lint
# When present, only those suites are used (others are unset).
# This lets a spec override the project's default suites without
# editing .auto_claude.conf.

_spec_suite_override=""
if [ -f "$SPEC_FILE" ]; then
  _spec_suite_override=$(grep -m1 '^# auto_claude: test_suites=' "$SPEC_FILE" 2>/dev/null || true)
  if [ -n "$_spec_suite_override" ]; then
    _spec_suite_override="${_spec_suite_override#\# auto_claude: test_suites=}"
    _spec_suite_override="${_spec_suite_override//[[:space:]]/}"
  fi
fi

if [ -n "$_spec_suite_override" ]; then
  log INFO "Spec overrides test suites: ${_spec_suite_override}"
  # Unset all test_suite_* functions not in the override list
  IFS=',' read -ra _wanted <<< "$_spec_suite_override"
  for _existing in $(_discover_test_suites); do
    _keep=false
    for _w in "${_wanted[@]}"; do
      if [ "$_existing" = "test_suite_${_w}" ]; then _keep=true; break; fi
    done
    if [ "$_keep" = false ]; then
      log INFO "Unsetting suite: ${_existing#test_suite_} (not in spec override)"
      unset -f "$_existing"
    fi
  done
  unset _wanted _existing _w _keep
fi
unset _spec_suite_override

# ─── Validate Test Suites ───────────────────────────────────────────────────

_startup_suites=$(_discover_test_suites)
if [ -z "$_startup_suites" ]; then
  echo "ERROR: No test_suite_*() functions found in ${CONF_FILE}" >&2
  echo "Define at least one, e.g.:" >&2
  echo '  test_suite_jest() { npm test 2>&1 | tee -a "$LOG_FILE"; return ${PIPESTATUS[0]}; }' >&2
  exit 1
fi

log INFO "Discovered test suites:"
for _s in $_startup_suites; do
  log INFO "  - ${_s#test_suite_}"
done
unset _startup_suites _s

# ─── Discover CI Checks ──────────────────────────────────────────────────────

_auto_discover_ci_checks

_startup_ci_checks=$(_discover_ci_checks)
if [ -n "$_startup_ci_checks" ]; then
  log INFO "Discovered CI checks:"
  for _c in $_startup_ci_checks; do
    _ci_name="${_c#ci_check_}"
    _ci_strat="Claude-fixable"
    _has_ci_fix "$_ci_name" && _ci_strat="auto-fixable"
    log INFO "  - ${_ci_name} (${_ci_strat})"
  done
else
  log INFO "No CI checks configured — ci_checks phase will be skipped"
fi
unset _startup_ci_checks _c _ci_name _ci_strat

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
  local start_phase=1

  # Check for existing state file from a crashed run
  if [ -f "$STATE_FILE" ]; then
    local run_status
    run_status=$(_state_get '.run.status')

    if [ "$run_status" = "running" ]; then
      # Check if the spec file changed since the interrupted run
      local saved_spec
      saved_spec=$(_state_get '.run.spec_file // empty')
      if [ -n "$saved_spec" ] && [ "$saved_spec" != "$SPEC_FILE" ]; then
        log WARN "State file is from a different spec: $(basename "$saved_spec")"
        log WARN "Current spec: $(basename "$SPEC_FILE")"
        log INFO "Starting fresh (spec mismatch)"
        rm -f "$STATE_FILE"
      else
        log WARN "Found interrupted pipeline state"
      fi
    fi

    # Re-check after possible cleanup above
    if [ -f "$STATE_FILE" ] && [ "$(_state_get '.run.status')" = "running" ]; then

      # Restore baseline commit from state
      BASELINE_COMMIT=$(_state_get '.run.baseline_commit')
      if [ -n "$BASELINE_COMMIT" ] && [ "$BASELINE_COMMIT" != "null" ]; then
        log INFO "Baseline commit: ${BASELINE_COMMIT:0:12}..."
      fi

      # Find last completed phase and compute start_phase
      local phase_idx=0
      for phase_name in "${PHASES[@]}"; do
        phase_idx=$((phase_idx + 1))
        local pstatus
        pstatus=$(_state_get ".phases.\"${phase_name}\".status // empty")
        if [ "$pstatus" = "completed" ]; then
          start_phase=$((phase_idx + 1))
          # Track seam crossing
          if [ "$phase_name" = "$SEAM_AFTER" ]; then
            _PAST_SEAM=true
          fi
        fi
      done

      # Get session ID from the last recorded phase for resume
      local last_session
      last_session=$(_state_get '[.phases | to_entries[] | select(.value.session_id != "" and .value.session_id != null)] | last.value.session_id // empty')
      if [ -n "$last_session" ] && [ "$last_session" != "null" ]; then
        RESUME_SESSION_ID="$last_session"
        log INFO "Resumable session: ${last_session:0:12}..."
      fi

      log INFO "Resuming from phase ${start_phase}"
    else
      # Previous run completed — start fresh
      log INFO "Previous run completed. Starting fresh."
      rm -f "$STATE_FILE"
    fi
  fi

  # Fresh run — initialize state and baseline
  if [ ! -f "$STATE_FILE" ]; then
    if [ "$HAS_GIT" = true ]; then
      BASELINE_COMMIT="$(git rev-parse HEAD 2>/dev/null)" || true
      # Snapshot untracked files so we can subtract them later
      git -C "$PROJECT_ROOT" ls-files --others --exclude-standard 2>/dev/null | sort > "$BASELINE_FILE"
      log INFO "Baseline snapshot: commit ${BASELINE_COMMIT:0:12}..., $(wc -l < "$BASELINE_FILE" | tr -d ' ') untracked files"
    fi
    _init_state
  fi

  _load_ownership_manifest

  # Apply --skip flags: mark requested phases as completed so the loop skips them
  if [ -n "$_CLI_SKIP_PHASES" ]; then
    IFS=',' read -ra _skip_arr <<< "$_CLI_SKIP_PHASES"
    for _sp in "${_skip_arr[@]}"; do
      # Validate phase name
      local _found=false
      for _p in "${PHASES[@]}"; do
        if [ "$_p" = "$_sp" ]; then _found=true; break; fi
      done
      if [ "$_found" = false ]; then
        log ERROR "Unknown phase in --skip: $_sp (valid: ${PHASES[*]})"
        exit 1
      fi
      _update_phase_status "$_sp" "completed"
      log INFO "Phase '${_sp}' marked as skipped (--skip)"
    done
    unset _skip_arr _sp _p _found
  fi

  log INFO "Starting auto_claude pipeline"
  log INFO "Project: ${PROJECT_NAME}"
  log INFO "Spec: ${SPEC_FILE}"
  log INFO "Log: ${LOG_FILE}"
  log INFO "State: ${STATE_FILE}"
  log INFO "Max LOC: ${MAX_LOC}"
  log INFO "Max test iterations: ${MAX_TEST_ITERATIONS}"
  log INFO "Phases: ${PHASES[*]}"
  log INFO "Seam after: ${SEAM_AFTER}"

  local phase_idx=0
  for phase_name in "${PHASES[@]}"; do
    phase_idx=$((phase_idx + 1))

    # Check if this phase was skipped (--skip flag or already completed)
    local pstatus
    pstatus=$(_state_get ".phases.\"${phase_name}\".status // empty")
    if [ "$pstatus" = "completed" ] && [ "$start_phase" -le "$phase_idx" ]; then
      log INFO "═══ Phase ${phase_idx}/${#PHASES[@]}: ${phase_name} (skipped) ═══"
      if [ "$phase_name" = "$SEAM_AFTER" ]; then
        _PAST_SEAM=true
      fi
      continue
    fi

    if [ "$start_phase" -le "$phase_idx" ]; then
      CURRENT_PHASE_NAME="$phase_name"
      log INFO "═══ Phase ${phase_idx}/${#PHASES[@]}: ${phase_name} ═══"

      _update_phase_status "$phase_name" "in_progress"

      "phase_${phase_name}"

      _update_phase_status "$phase_name" "completed"
      _update_deterministic_state

      # Run extraction at the authoring/quality seam (once)
      if [ "$phase_name" = "$SEAM_AFTER" ] && [ "$_PAST_SEAM" = false ]; then
        _extract_authoring_summary
        _audit_test_deletions
        _PAST_SEAM=true
      fi

      # If we just crossed the seam via skip (resume case) but extraction never ran,
      # run it now before the first quality phase executes.
      if [ "$_PAST_SEAM" = true ] && [ "$phase_name" != "$SEAM_AFTER" ]; then
        local _intent_extracted
        _intent_extracted=$(_state_get '.semantic.plan_intent // empty')
        if [ -z "$_intent_extracted" ]; then
          log INFO "Seam extraction missing (interrupted resume) — running now"
          _extract_authoring_summary
          _audit_test_deletions
        fi
      fi

      # Track completed quality phases in state for downstream context packs
      if [ "$_PAST_SEAM" = true ] && [ "$phase_name" != "$SEAM_AFTER" ]; then
        _jq_update --arg p "$phase_name" \
          '.semantic.completed_quality_phases += [$p]'
      fi
    fi
  done

  # Mark run as completed, clean up transient files
  _jq_update '.run.status = "completed"'
  rm -f "$BASELINE_FILE"

  log OK "═══ All ${#PHASES[@]} phases complete ═══"
  log INFO "State: jq . ${STATE_FILE}"
}

_acquire_lock
main "$@"
