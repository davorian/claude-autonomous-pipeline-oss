#!/bin/bash
# auto_claude — Reusable autonomous feature pipeline
#
# A generic pipeline engine that sources project-specific configuration
# from .auto_claude.conf in the project root. All infrastructure (logging,
# Claude invocation, structured state, test-fix loop, phase sequencing)
# lives here. Project-specific content (test commands, review criteria,
# prompt fragments) lives in the conf.
#
# Usage: auto_claude <path-to-spec.md>
#
# Requires: .auto_claude.conf in the git root with at least one test_suite_*() function.
#
# Architecture: The pipeline splits into two blocks at a configurable seam:
#
#   Authoring block (plan → implement → test_fix → ci_checks):
#     Single Claude conversation via --continue. Full context for accurate
#     implementation and debugging. ci_checks auto-fixes formatting/lint and
#     sends type errors to Claude while it still has full context.
#
#   Quality block (skill_chain → loc_enforcement → fresh_review → doc_update → final):
#     Each phase gets a fresh Claude session with a tailored context pack
#     assembled from structured state. Sequential — each feeds into the next.
#
# Structured state (.auto_claude_state.json) replaces the old checkpoint,
# transcript, and baseline files with a single inspectable JSON file.

set -Eeuo pipefail
trap 'rc=$?; log ERROR "Pipeline failed at line $LINENO (exit $rc)"; exit 1' ERR

# Force CI mode so test runners (vitest, jest, etc.) run non-interactively.
# Without this, vitest detects the TTY and enters watch mode, hanging the pipeline.
export CI=true

# Ctrl+C should kill the whole process tree, not hang inside a subshell.
# Without this, claude running inside a subshell swallows SIGINT and the user
# has to close the terminal window to escape.
# NOTE: These traps are replaced by _acquire_lock() with lock-aware versions.
# They exist here only for the pre-lock startup phase.
trap 'echo ""; log WARN "Interrupted by user"; kill 0 2>/dev/null; exit 130' INT TERM

# Verify jq is available (used for JSON parsing of claude output and state file)
if ! command -v jq &>/dev/null; then
  echo "ERROR: jq is required but not found. Install with: brew install jq" >&2
  exit 1
fi

# ─── Configuration Defaults ──────────────────────────────────────────────────
# All overridable in .auto_claude.conf

MAX_TEST_ITERATIONS=5
MAX_REFACTOR_ROUNDS=10
MAX_LOC=300
MAX_CI_ITERATIONS=3
SUITE_IDLE_TIMEOUT=120  # seconds of no new output before killing a suite; 0 = no timeout
PHASES=(plan decisions test_intent pattern_baseline implement test_fix ci_checks impact skill_chain loc_enforcement fresh_review doc_update final)

# Tiered escalation thresholds. Each value is the iteration where a new tier begins.
# Tier 1 (tactical):  iterations 1 to TIER_2_AT-1
# Tier 2 (re-anchor): iterations TIER_2_AT to TIER_3_AT-1
# Tier 3 (consult):   iteration TIER_3_AT (generates alternatives)
# Tier 4 (human):     iteration TIER_4_AT (presents alternatives, pauses)
TIER_2_AT=3
TIER_3_AT=4
TIER_4_AT=5
ESCALATION_ENABLED=true  # Set false to use flat loop (backward compat)

# TDD — write tests before implementation
TDD_LAYERS="unit,integration"  # test layers to write: unit,integration,component,e2e
TDD_ENABLED=true               # set false to skip test_intent and use old behaviour

# Pattern conformance — derive patterns from adjacent code and check implementation
PATTERN_CONFORMANCE=true  # set false to skip pattern baseline + conformance review

# The last phase in the authoring block. Extraction happens after this phase
# and all subsequent phases get fresh sessions with structured context packs.
SEAM_AFTER="ci_checks"

# Prompt fragment variables — injected into generic phase prompts.
# Set these in .auto_claude.conf to add project-specific context.
PLAN_CONTEXT=""
REVIEW_EXTRAS=""
SECURITY_EXTRAS=""
FRESH_REVIEW_PREAMBLE=""
FRESH_REVIEW_EXTRAS=""
DOC_UPDATE_CONTEXT=""

# File glob patterns — overridable in .auto_claude.conf.
# TEST_FILE_GLOBS: patterns for test files (used by test audit to detect test changes).
# SOURCE_FILE_GLOBS: patterns for source files (used by LOC enforcement to find long files).
TEST_FILE_GLOBS=("*.test.ts" "*.test.tsx" "*.spec.ts" "*.spec.tsx" "*.test.js" "*.spec.js" "*.test.ex" "*.test.exs" "*_test.go" "*_test.rb" "test_*.py" "*_test.py")
SOURCE_FILE_GLOBS=("*.ts" "*.tsx" "*.js" "*.jsx" "*.py" "*.go" "*.rs" "*.rb" "*.ex" "*.exs" "*.kt" "*.swift")

# Explainability phase configuration — all overridable in .auto_claude.conf
EXPLAIN_PHASES=true           # Master switch — set false to disable all explainability
DECISIONS_REVIEW=false        # Pause after decisions manifest for human review
COVERAGE_GATE=false           # Pause if high-severity coverage gaps found
ARTIFACTS_DIR=""              # Override auto-detection of recovery artifacts. Empty = auto-detect.

# Opinionated mode — injects architectural standards into phase prompts.
# Settable in .auto_claude.conf or overridden per-run via --opinionated CLI flag.
# When true, phases defer to existing codebase patterns, apply discriminated
# unions over optional fields, use ports/adapters at natural seams, and default
# to the simpler of two options unless explicitly instructed otherwise.
OPINIONATED=false

# ─── Auto-detect Project Root ────────────────────────────────────────────────
# Tries git first (works from any subdirectory, handles symlinks). If not in a
# git repo, walks up from pwd looking for .auto_claude.conf — because that file
# must exist for the pipeline to run, it doubles as a reliable project marker.

HAS_GIT=false
if PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  HAS_GIT=true
else
  # Walk up from pwd looking for .auto_claude.conf
  _dir="$(pwd)"
  while [ "$_dir" != "/" ]; do
    if [ -f "${_dir}/.auto_claude.conf" ]; then
      PROJECT_ROOT="$_dir"
      break
    fi
    _dir="$(dirname "$_dir")"
  done
  unset _dir

  if [ -z "${PROJECT_ROOT:-}" ]; then
    echo "ERROR: Could not detect project root." >&2
    echo "Either run from inside a git repo, or ensure .auto_claude.conf exists in an ancestor directory." >&2
    exit 1
  fi
fi
PROJECT_NAME="$(basename "$PROJECT_ROOT")"

# ─── Arguments ───────────────────────────────────────────────────────────────

_CLI_OPINIONATED=false
_CLI_SKIP_PHASES=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --opinionated) _CLI_OPINIONATED=true; shift ;;
    --skip) _CLI_SKIP_PHASES="${_CLI_SKIP_PHASES:+${_CLI_SKIP_PHASES},}${2:?--skip requires a phase name}"; shift 2 ;;
    --) shift; break ;;
    -*) echo "ERROR: Unknown flag: $1" >&2; echo "Usage: auto_claude [--opinionated] [--skip <phase>]... <path-to-spec.md>" >&2; exit 1 ;;
    *) break ;;
  esac
done

SPEC_FILE="${1:?Usage: auto_claude [--opinionated] [--skip <phase>]... <path-to-spec.md>}"
# Resolve to absolute path so cd's in test suites do not break the reference
if [[ "$SPEC_FILE" != /* ]]; then
  SPEC_FILE="$(pwd)/$SPEC_FILE"
fi

# ─── Runtime Paths ───────────────────────────────────────────────────────────

LOG_FILE="${PROJECT_ROOT}/.auto_claude_$(date +%Y%m%d_%H%M%S).log"
STATE_FILE="${PROJECT_ROOT}/.auto_claude_state.json"
BASELINE_FILE="${PROJECT_ROOT}/.auto_claude_baseline"
LOCK_FILE="${PROJECT_ROOT}/.auto_claude.lock"
EXPLAIN_DIR="${PROJECT_ROOT}/.auto_claude_explain"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ─── Concurrency Guard ─────────────────────────────────────────────────────
# Only one auto_claude instance may run per project. A second instance on the
# same repo would corrupt the shared state file and collide on --continue.
# Uses mkdir (atomic on all filesystems) instead of flock (not on macOS).

_acquire_lock() {
  if mkdir "$LOCK_FILE" 2>/dev/null; then
    # Write PID so stale locks can be diagnosed
    echo "$$" > "$LOCK_FILE/pid"
    # Clean up lock on any exit (normal, error, signal)
    trap 'rc=$?; _release_lock; log ERROR "Pipeline failed at line $LINENO (exit $rc)"; exit 1' ERR
    trap '_release_lock; echo ""; log WARN "Interrupted by user"; kill 0 2>/dev/null; exit 130' INT TERM
    trap '_release_lock' EXIT
    return 0
  fi

  # Lock exists — check if the holding process is still alive
  local holder_pid=""
  if [ -f "$LOCK_FILE/pid" ]; then
    holder_pid=$(<"$LOCK_FILE/pid")
  fi

  if [ -n "$holder_pid" ] && kill -0 "$holder_pid" 2>/dev/null; then
    echo "ERROR: Another auto_claude is running (PID $holder_pid)." >&2
    echo "       If this is stale, remove: rm -rf $LOCK_FILE" >&2
    exit 1
  else
    echo "WARN: Removing stale lock from dead process (PID ${holder_pid:-unknown})." >&2
    rm -rf "$LOCK_FILE"
    # Retry once
    _acquire_lock
  fi
}

_release_lock() {
  rm -rf "$LOCK_FILE" 2>/dev/null || true
}

# ─── Pipeline State ──────────────────────────────────────────────────────────

CURRENT_SESSION_ID=""
RESUME_SESSION_ID=""
BASELINE_COMMIT=""
CURRENT_PHASE_NAME=""
LAST_RESPONSE_TEXT=""

# Prompt suffix to prevent Claude from asking questions mid-pipeline
NO_QUESTIONS="Do not ask questions. Make reasonable decisions based on the spec, governance docs, and codebase context. If truly ambiguous, choose the simpler option and note your assumption."

# Test suite results — populated by _run_all_suites
LAST_PASSED_SUITES=""
LAST_FAILED_SUITES=""
LAST_TEST_OUTPUT=""

# Track whether we've passed the authoring/quality seam
_PAST_SEAM=false

# ─── Helpers ─────────────────────────────────────────────────────────────────

log() {
  local level="$1"
  shift
  local msg="$*"
  local timestamp
  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"

  case "$level" in
    INFO)  printf "\033[0;34m[%s INFO]\033[0m %s\n" "$timestamp" "$msg" ;;
    OK)    printf "\033[0;32m[%s OK]\033[0m %s\n" "$timestamp" "$msg" ;;
    WARN)  printf "\033[0;33m[%s WARN]\033[0m %s\n" "$timestamp" "$msg" ;;
    ERROR) printf "\033[0;31m[%s ERROR]\033[0m %s\n" "$timestamp" "$msg" ;;
    *)     printf "[%s] %s\n" "$timestamp" "$msg" ;;
  esac

  printf "[%s %s] %s\n" "$timestamp" "$level" "$msg" >> "$LOG_FILE"
}

# ─── Artifact Detection & Access ─────────────────────────────────────────────
# Recovery artifacts enrich explainability but are never required.
# ARTIFACTS_DIR can be set in .auto_claude.conf to override auto-detection.

HAS_ARTIFACTS=false  # set by _detect_artifacts at startup

_detect_artifacts() {
  if [ "${EXPLAIN_PHASES:-true}" != "true" ]; then
    HAS_ARTIFACTS=false
    ARTIFACTS_DIR=""
    log INFO "Explainability phases disabled (EXPLAIN_PHASES=false)"
    return
  fi

  # Explicit config takes precedence
  if [ -n "${ARTIFACTS_DIR:-}" ] && [ -d "$ARTIFACTS_DIR" ]; then
    HAS_ARTIFACTS=true
    log INFO "Artifacts directory: $ARTIFACTS_DIR"
    return
  fi

  # Auto-detect: check project root, then parent directory (monorepo layout)
  for candidate in \
    "$PROJECT_ROOT/.recovery_artifacts" \
    "$(dirname "$PROJECT_ROOT")/.recovery_artifacts"; do
    if [ -d "$candidate" ] && [ -f "$candidate/system_graph.json" ]; then
      ARTIFACTS_DIR="$candidate"
      HAS_ARTIFACTS=true
      log INFO "Auto-detected artifacts: $ARTIFACTS_DIR"
      return
    fi
  done

  HAS_ARTIFACTS=false
  ARTIFACTS_DIR=""
  log INFO "No recovery artifacts found — explainability phases will use LLM-only mode"
}

_read_artifact() {
  local name="$1"
  local file="$ARTIFACTS_DIR/${name}.json"

  if [ ! -f "$file" ]; then
    log DEBUG "Artifact not found: $name (skipping)"
    echo ""
    return
  fi

  if ! jq '.' "$file" >/dev/null 2>&1; then
    log WARN "Artifact malformed: $name (skipping)"
    echo ""
    return
  fi

  cat "$file"
}

_ensure_explain_dir() {
  mkdir -p "$EXPLAIN_DIR"
}

# Parse JSON from LAST_RESPONSE_TEXT. Prefers the Go helper (`ac-helper
# extract-json`) when available — it handles all three extraction tiers
# natively and avoids a class of pure-bash parsing bugs (multi-line output
# leaking into numeric tests, ERR-trap propagation through command
# substitutions). Falls back to the hardened bash implementation otherwise.
#
# Tiers:
#   1. Raw parse — response is pure JSON
#   2. Markdown fence — JSON wrapped in ```json ... ```
#   3. Brace extraction — JSON embedded in prose (e.g. "Here's the manifest:\n{...}")
# Echoes the parsed JSON on success, empty string on failure.
_extract_json_from_response() {
  # Go helper fast-path
  if command -v ac-helper >/dev/null 2>&1; then
    local go_parsed
    if go_parsed=$(printf '%s' "$LAST_RESPONSE_TEXT" | ac-helper extract-json 2>/dev/null); then
      echo "$go_parsed"
      return 0
    fi
    echo ""
    return 1
  fi

  local parsed=""
  # Tier 1: raw JSON
  if parsed=$(echo "$LAST_RESPONSE_TEXT" | jq '.' 2>/dev/null); then
    echo "$parsed"
    return 0
  fi

  # Tier 2: markdown fence extraction
  local extracted
  extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n '/^```\(json\)\{0,1\}$/,/^```$/p' | sed '1d;$d')
  if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
    echo "$parsed"
    return 0
  fi

  # Tier 3: find first { and last } — handles prose before/after JSON.
  # tr -cd '0-9' sanitises against multi-line or garbled grep output that
  # would otherwise trip the numeric `-le` test; the trailing 2>/dev/null
  # on the comparison silences any residual "integer expression expected"
  # noise. See helper/extract.go for the robust Go implementation.
  local first_brace last_brace
  first_brace=$(echo "$LAST_RESPONSE_TEXT" | grep -n '{' | head -1 | cut -d: -f1 | tr -cd '0-9')
  last_brace=$(echo "$LAST_RESPONSE_TEXT" | grep -n '}' | tail -1 | cut -d: -f1 | tr -cd '0-9')
  if [ -n "$first_brace" ] && [ -n "$last_brace" ] && [ "$first_brace" -le "$last_brace" ] 2>/dev/null; then
    extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n "${first_brace},${last_brace}p")
    if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
      echo "$parsed"
      return 0
    fi
  fi

  echo ""
  return 1
}

_filter_artifacts_for_spec() {
  [ "$HAS_ARTIFACTS" != true ] && return

  # Extract entity/table names from spec and plan (deterministic regex)
  local spec_entities=""
  if [ -f "$SPEC_FILE" ]; then
    spec_entities=$(grep -oiE '\b[a-z][a-z_]*[a-z]\b' "$SPEC_FILE" \
      | grep -iE '(table|view|_candidates|_cohorts|_programmes|_users|_companies|_qualifications|_apprentice|_employers|_goals|_sessions|_events)' \
      | sort -u || true)
  fi

  # Also include table names from FROM/JOIN/INTO clauses in plan output
  if [ -f "$SPEC_FILE" ]; then
    local sql_entities
    sql_entities=$(grep -oiE '(FROM|JOIN|INTO|UPDATE)\s+"?([a-z][a-z_]*)"?' "$SPEC_FILE" \
      | grep -oiE '[a-z][a-z_]+$' | sort -u || true)
    if [ -n "$sql_entities" ]; then
      spec_entities=$(printf '%s\n%s' "$spec_entities" "$sql_entities" | sort -u)
    fi
  fi

  [ -z "$spec_entities" ] && return

  local output=""

  # Data ownership excerpts for relevant entities
  local data_ownership
  data_ownership=$(_read_artifact "data_ownership")
  if [ -n "$data_ownership" ]; then
    local filtered
    filtered=$(echo "$data_ownership" | python3 -c "
import json, sys
data = json.load(sys.stdin)
names = [n.strip().lower() for n in sys.argv[1].split('\n') if n.strip()]
matched = [e for e in data.get('entities', []) if e.get('name','').lower() in names]
if matched: print(json.dumps(matched, indent=2))
" "$spec_entities" 2>/dev/null || echo "")
    if [ -n "$filtered" ] && [ "$filtered" != "[]" ]; then
      output+="### Data Ownership (relevant entities)
\`\`\`json
${filtered}
\`\`\`

"
    fi
  fi

  # Invariants for relevant entities
  local invariants
  invariants=$(_read_artifact "invariants")
  if [ -n "$invariants" ]; then
    local filtered
    filtered=$(echo "$invariants" | python3 -c "
import json, sys
data = json.load(sys.stdin)
names = [n.strip().lower() for n in sys.argv[1].split('\n') if n.strip()]
matched = [i for i in data.get('invariants', []) if any(n in i.get('description','').lower() for n in names)]
if matched: print(json.dumps(matched[:10], indent=2))
" "$spec_entities" 2>/dev/null || echo "")
    if [ -n "$filtered" ] && [ "$filtered" != "[]" ]; then
      output+="### Invariants (relevant)
\`\`\`json
${filtered}
\`\`\`

"
    fi
  fi

  # Event contracts for relevant entities
  local events
  events=$(_read_artifact "event_contracts")
  if [ -n "$events" ]; then
    local filtered
    filtered=$(echo "$events" | python3 -c "
import json, sys
data = json.load(sys.stdin)
names = [n.strip().lower() for n in sys.argv[1].split('\n') if n.strip()]
matched = [e for e in data.get('events', []) if any(n in e.get('name','').lower() for n in names)]
if matched: print(json.dumps(matched[:10], indent=2))
" "$spec_entities" 2>/dev/null || echo "")
    if [ -n "$filtered" ] && [ "$filtered" != "[]" ]; then
      output+="### Event Contracts (relevant)
\`\`\`json
${filtered}
\`\`\`

"
    fi
  fi

  echo "$output"
}

# ─── Progress Spinner ────────────────────────────────────────────────────────
# Shows elapsed time while Claude is working. Only displays when stdout is a
# terminal. Killed automatically by the INT trap or by the caller.

_show_progress() {
  [ ! -t 1 ] && return
  local msg="$1"
  local start=$SECONDS
  while true; do
    local elapsed=$((SECONDS - start))
    local mins=$((elapsed / 60))
    local secs=$((elapsed % 60))
    printf "\r\033[0;36m⏳ %s [%d:%02d]\033[0m" "$msg" "$mins" "$secs"
    sleep 1
  done
}

# ─── Structured State File ───────────────────────────────────────────────────
#
# Single JSON file that replaces the old checkpoint, transcript, and baseline
# files. Two sections with different reliability guarantees:
#
#   deterministic — engine-populated from git and test runners. Always accurate.
#   semantic      — Claude-populated via extraction call at the seam. Richer but lossy.
#
# State is updated after every phase. Quality phases read it via context packs.

_init_state() {
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  jq -n \
    --arg spec "$SPEC_FILE" \
    --arg root "$PROJECT_ROOT" \
    --arg name "$PROJECT_NAME" \
    --arg baseline "${BASELINE_COMMIT:-}" \
    --arg started "$now" \
    '{
      schema_version: 1,
      run: {
        spec_file: $spec,
        project_root: $root,
        project_name: $name,
        baseline_commit: $baseline,
        started_at: $started,
        status: "running"
      },
      phases: {},
      deterministic: {
        files_changed: [],
        files_created: [],
        test_results: {
          final_status: "pending",
          iterations_needed: 0,
          suites: {}
        },
        loc_status: {
          over_limit: [],
          max_observed: 0
        },
        ci_checks_results: {
          checks_discovered: [],
          final_status: "pending",
          iterations_needed: 0,
          auto_fixed: [],
          claude_fixed: []
        },
        approach_journal: [],
        escalation: {
          alternatives: [],
          diagnosis: null,
          chosen: null,
          tier_reached: 0
        },
        tdd_status: null
      },
      semantic: {
        plan_intent: null,
        plan_checklist: [],
        governance_ids: [],
        implementation_summary: null,
        key_decisions: [],
        test_fix_summary: null,
        completed_quality_phases: [],
        skill_chain_findings: null,
        review_findings: null,
        doc_update_summary: null,
        test_audit: null,
        intent_map: null,
        decisions_manifest: null,
        pattern_baseline: null,
        conformance_findings: null
      }
    }' > "$STATE_FILE"

  log INFO "State file initialized: $STATE_FILE"
}

# ─── Ownership Manifest ─────────────────────────────────────────────────────
#
# When running inside a worktree fork (worktree_auto_claude), an ownership
# manifest maps this run to the files it owns, may read, and must not touch.
# In standalone mode (no manifest or no env var), all are empty — no enforcement.

OWNERSHIP_OWNS=""
OWNERSHIP_READS=""
OWNERSHIP_MUST_NOT_TOUCH=""

_load_ownership_manifest() {
  local manifest="${PROJECT_ROOT}/.auto_claude_ownership.json"
  if [ ! -f "$manifest" ]; then
    return 0
  fi

  local run_name="${AUTO_CLAUDE_RUN_NAME:-}"
  if [ -z "$run_name" ]; then
    log INFO "Ownership manifest found but AUTO_CLAUDE_RUN_NAME not set — standalone mode"
    return 0
  fi

  local entry
  entry=$(jq -r --arg name "$run_name" '.runs[$name] // empty' "$manifest" 2>/dev/null)
  if [ -z "$entry" ]; then
    log WARN "Ownership manifest has no entry for run '${run_name}'"
    return 0
  fi

  OWNERSHIP_OWNS=$(echo "$entry" | jq -r '(.owns // [])[]' 2>/dev/null) || true
  OWNERSHIP_READS=$(echo "$entry" | jq -r '(.reads // [])[]' 2>/dev/null) || true
  OWNERSHIP_MUST_NOT_TOUCH=$(echo "$entry" | jq -r '(.must_not_touch // [])[]' 2>/dev/null) || true

  local own_count read_count fence_count
  own_count=$(echo "$OWNERSHIP_OWNS" | grep -c . 2>/dev/null || echo 0)
  read_count=$(echo "$OWNERSHIP_READS" | grep -c . 2>/dev/null || echo 0)
  fence_count=$(echo "$OWNERSHIP_MUST_NOT_TOUCH" | grep -c . 2>/dev/null || echo 0)
  log INFO "Ownership loaded: ${own_count} owned, ${read_count} read-only, ${fence_count} fenced"
}

_build_ownership_context() {
  if [ -z "$OWNERSHIP_OWNS" ] && [ -z "$OWNERSHIP_READS" ] && [ -z "$OWNERSHIP_MUST_NOT_TOUCH" ]; then
    return 0
  fi

  local owns_list reads_list fence_list
  owns_list=$(echo "$OWNERSHIP_OWNS" | sed '/^$/d' | sed 's/^/  - /') || true
  reads_list=$(echo "$OWNERSHIP_READS" | sed '/^$/d' | sed 's/^/  - /') || true
  fence_list=$(echo "$OWNERSHIP_MUST_NOT_TOUCH" | sed '/^$/d' | sed 's/^/  - /') || true

  echo "## File Ownership Boundaries
You OWN (read-write):
${owns_list:-  (none)}
You may READ (read-only):
${reads_list:-  (none)}
You MUST NOT TOUCH:
${fence_list:-  (none)}
If you need a change in a read-only or fenced file, add a \`// TODO(boundary): <description of what you need>\` comment in the closest owned file. Do NOT modify files in the MUST NOT TOUCH list."
}

# Read a value from the state file via jq expression.
_state_get() {
  jq -r "$1" "$STATE_FILE" 2>/dev/null
}

# Safe jq state update. Reads STATE_FILE, applies the jq filter, and atomically
# replaces it. Exits with explicit error if jq fails (don't rely on set -e
# propagation through && chains, which is broken in bash 3.2).
_jq_update() {
  # All args except the last are jq flags; the last is the filter expression
  if ! jq "$@" "$STATE_FILE" > "${STATE_FILE}.tmp"; then
    log ERROR "jq state update failed (filter: ${*: -1})"
    rm -f "${STATE_FILE}.tmp"
    return 1
  fi
  mv "${STATE_FILE}.tmp" "$STATE_FILE"
}

# Update phase status (in_progress | completed) with timestamp and session ID.
_update_phase_status() {
  local phase="$1" status="$2"
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local session="${CURRENT_SESSION_ID:-}"

  if [ "$status" = "in_progress" ]; then
    _jq_update --arg p "$phase" --arg s "$status" --arg t "$now" --arg sid "$session" \
      '.phases[$p] = ((.phases[$p] // {}) + {status: $s, session_id: $sid, started_at: $t})'
  elif [ "$status" = "completed" ]; then
    _jq_update --arg p "$phase" --arg s "$status" --arg t "$now" --arg sid "$session" \
      '.phases[$p] = ((.phases[$p] // {}) + {status: $s, session_id: $sid, completed_at: $t})'
  fi
}

# Refresh deterministic state from git. Called after every phase.
_update_deterministic_state() {
  if [ "$HAS_GIT" = false ]; then return 0; fi
  cd "$PROJECT_ROOT"

  # All files that changed during this session (tracked + new untracked)
  local all_changed
  all_changed=$(get_changed_files)

  # New untracked files only (files created during this session)
  local new_untracked=""
  local current_untracked
  current_untracked=$(git ls-files --others --exclude-standard 2>/dev/null)
  if [ -f "$BASELINE_FILE" ]; then
    new_untracked=$(comm -23 <(echo "$current_untracked" | sort) <(sort "$BASELINE_FILE"))
  fi

  # Convert newline-separated lists to JSON arrays
  local changed_json created_json
  # sed strips blank lines (grep -v '^$' exits 1 on no match, which triggers ERR with -E)
  changed_json=$(echo "$all_changed" | sed '/^$/d' | jq -R . | jq -s '.' 2>/dev/null || echo '[]')
  created_json=$(echo "$new_untracked" | sed '/^$/d' | jq -R . | jq -s '.' 2>/dev/null || echo '[]')

  _jq_update --argjson changed "$changed_json" --argjson created "$created_json" \
    '.deterministic.files_changed = $changed | .deterministic.files_created = $created'
}

# Update test results in deterministic state.
_update_test_results() {
  local final_status="$1" iterations="$2"

  # Build suites JSON from the LAST_PASSED/FAILED globals
  local suites_json="{}"
  for name in $LAST_PASSED_SUITES; do
    suites_json=$(echo "$suites_json" | jq --arg n "$name" '. + {($n): {"status": "pass", "exit_code": 0}}')
  done
  for name in $LAST_FAILED_SUITES; do
    suites_json=$(echo "$suites_json" | jq --arg n "$name" '. + {($n): {"status": "fail", "exit_code": 1}}')
  done

  _jq_update --arg s "$final_status" --argjson i "$iterations" --argjson suites "$suites_json" \
    '.deterministic.test_results = {final_status: $s, iterations_needed: $i, suites: $suites}'
}

# Record what was tried in a test_fix iteration. Called after each fix attempt
# via run_claude. Appends a structured entry to the approach journal in state.
_record_approach() {
  local iteration="$1"

  run_claude "Summarise in ONE sentence what you just changed to fix the test failures,
and in ONE sentence what error pattern you were addressing.
Output ONLY valid JSON (no markdown fences, no commentary):
{\"summary\": \"...\", \"error_class\": \"...\", \"files_touched\": [\"file1.ts\", \"file2.ts\"]}"

  local parsed=""
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      _jq_update --argjson entry "$parsed" --argjson i "$iteration" \
        '.deterministic.approach_journal += [($entry + {iteration: $i})]'
      log OK "Approach journal: iteration ${iteration} recorded"
      return 0
    fi
  fi

  # Fallback: record that extraction failed so the journal still tracks the iteration
  log WARN "Could not parse approach summary for iteration ${iteration} — recording fallback"
  _jq_update --argjson i "$iteration" \
    '.deterministic.approach_journal += [{iteration: $i, summary: "(extraction failed)", error_class: "unknown", files_touched: []}]'
}

# Format the approach journal for injection into test_fix prompts.
# Returns formatted string, or empty string if no entries.
_format_approach_journal() {
  local journal
  journal=$(jq -r '
    (.deterministic.approach_journal // []) |
    if length == 0 then ""
    else
      "PREVIOUS ATTEMPTS (do NOT repeat these — they all failed):\n" +
      ([ .[] |
        "- Iteration " + (.iteration | tostring) + ": " + .summary +
        " [error: " + .error_class + "]" +
        " [files: " + (.files_touched | join(", ")) + "]"
      ] | join("\n"))
    end
  ' "$STATE_FILE" 2>/dev/null) || true

  echo "$journal"
}

# Determine escalation tier for a given test_fix iteration.
_tier_for_iteration() {
  local iteration="$1"
  if [ "$iteration" -lt "$TIER_2_AT" ]; then echo 1
  elif [ "$iteration" -lt "$TIER_3_AT" ]; then echo 2
  elif [ "$iteration" -lt "$TIER_4_AT" ]; then echo 3
  else echo 4; fi
}

# ─── Claude Invocation ───────────────────────────────────────────────────────
#
# _invoke_claude — Single point for all Claude calls. Runs claude with a
#   progress spinner, parses JSON output, updates session tracking, and
#   stores the response in LAST_RESPONSE_TEXT for extraction parsing.
#
# run_claude — Continues the authoring conversation. On resume from crash,
#   uses a three-tier fallback: --resume <id> → --continue → state injection.
#
# run_claude_fresh — Starts a new conversation (for quality phases).

_invoke_claude() {
  local prompt="$1"
  shift
  local full_prompt="${prompt} ${NO_QUESTIONS}"

  # --dangerously-skip-permissions is required because the pipeline is autonomous.
  # Without it, claude prompts for tool approval, but since output is captured
  # there's no way to respond — the process hangs.
  local cmd=(claude -p "$full_prompt" --dangerously-skip-permissions --output-format json)
  if [ $# -gt 0 ]; then
    cmd+=("$@")
  fi

  local tmp_output exit_code=0
  tmp_output=$(mktemp)

  # Show progress spinner while Claude works
  local spinner_pid=""
  if [ -t 1 ]; then
    _show_progress "${CURRENT_PHASE_NAME:-Claude} ..." &
    spinner_pid=$!
    # Disown so the spinner doesn't produce job control messages
    disown "$spinner_pid" 2>/dev/null || true
  fi

  # Run claude, capture output to temp file
  "${cmd[@]}" > "$tmp_output" 2>&1 || exit_code=$?

  # Stop spinner and clear the line
  if [ -n "$spinner_pid" ]; then
    kill "$spinner_pid" 2>/dev/null
    wait "$spinner_pid" 2>/dev/null || true
    printf "\r\033[K"
  fi

  local raw_output
  raw_output=$(<"$tmp_output")
  rm -f "$tmp_output"

  # Parse session ID and response text from JSON.
  # Prefer the Go helper when available — its contract is "never fail",
  # which prevents jq/here-string corner cases from firing the global ERR
  # trap via command-substitution propagation.
  # Fallback: keep `|| true` *inside* the $(...) so a jq failure exits the
  # subshell at 0 rather than leaking to the assignment.
  local session_id response_text
  if command -v ac-helper >/dev/null 2>&1; then
    session_id=$(printf '%s' "$raw_output" | ac-helper parse-claude-response --field=session_id 2>/dev/null)
    response_text=$(printf '%s' "$raw_output" | ac-helper parse-claude-response --field=result 2>/dev/null)
  else
    session_id=$(jq -r '.session_id // empty' <<< "$raw_output" 2>/dev/null || true)
    response_text=$(jq -r '.result // empty' <<< "$raw_output" 2>/dev/null || true)
  fi

  # If JSON parsing failed, treat raw output as response text
  if [ -z "$response_text" ]; then
    response_text="$raw_output"
  fi

  # Update session tracking
  if [ -n "$session_id" ]; then
    CURRENT_SESSION_ID="$session_id"
  fi

  # Store for extraction parsing
  LAST_RESPONSE_TEXT="$response_text"

  # Display and log
  echo "$response_text" | tee -a "$LOG_FILE"

  return $exit_code
}

# Continue the authoring conversation. On resume from crash, uses a three-tier
# fallback: --resume <id> → --continue → structured state injection.
run_claude() {
  local prompt="$1"
  log INFO "Running Claude: ${prompt:0:80}..."

  # Resuming from crash — try the fallback chain
  if [ -n "$RESUME_SESSION_ID" ]; then
    local saved_id="$RESUME_SESSION_ID"
    RESUME_SESSION_ID=""  # Clear so subsequent calls use --continue

    log INFO "Resuming session ${saved_id:0:12}..."
    if _invoke_claude "$prompt" --resume "$saved_id"; then
      return 0
    fi

    log WARN "Session resume failed, trying --continue..."
    if _invoke_claude "$prompt" --continue; then
      return 0
    fi

    # Last resort: inject structured state into fresh context.
    # This replaces the old raw transcript injection — structured state
    # is more targeted and less noisy.
    if [ -f "$STATE_FILE" ]; then
      log WARN "--continue failed, falling back to structured state..."
      local state_context
      state_context=$(_build_context_pack "final")
      _invoke_claude "Context from previous pipeline phases:

${state_context}

---

${prompt}"
      return $?
    fi

    log WARN "No fallback available, starting fresh..."
    _invoke_claude "$prompt"
    return $?
  fi

  # Normal execution — continue the conversation
  _invoke_claude "$prompt" --continue
}

# Start a new conversation (no --continue). Used for quality phases that
# receive context packs instead of relying on conversation memory.
run_claude_fresh() {
  local prompt="$1"
  log INFO "Running Claude (fresh context): ${prompt:0:80}..."
  _invoke_claude "$prompt"
}

# ─── Extraction Protocol ─────────────────────────────────────────────────────
#
# Called once at the authoring/quality seam (after test_fix, before skill_chain).
# Asks Claude to summarise the authoring work into structured JSON, then merges
# it into the state file's semantic section. This is the single extra Claude call
# that funds all subsequent fresh sessions with bounded context.

_extract_authoring_summary() {
  log INFO "Extracting authoring summary at seam..."

  run_claude "You have completed the planning, implementation, and test-fixing phases. Before moving to code review, summarise your work as structured JSON.

Additionally, list all assumptions your implementation depends on that are NOT verified by the tests you wrote. Focus on:
- Data model assumptions (table vs view, column semantics, implicit filters)
- Ordering assumptions (this script runs after X, Y must have happened first)
- Environment assumptions (config values, feature flags, external service state)
- Concurrency assumptions (no other process modifies this data concurrently)

Output ONLY valid JSON (no markdown fences, no commentary before or after). Use these exact fields:

{
  \"plan_intent\": \"1-2 sentence summary of what was planned and why\",
  \"plan_checklist\": [\"short description of each plan item\"],
  \"governance_ids\": [\"principle IDs from CONTEXT_INDEX.md that were applied, or empty array\"],
  \"implementation_summary\": \"2-3 sentences describing what was built, key files, and approach\",
  \"key_decisions\": [{\"decision\": \"what was decided\", \"rationale\": \"why\"}],
  \"test_fix_summary\": \"what broke during testing and how it was fixed, or 'All tests passed on first iteration'\",
  \"assumptions_carried_forward\": [
    {
      \"id\": \"A001\",
      \"assumption\": \"description of what is assumed\",
      \"depends_on\": \"D1-001 or null if no link to decisions manifest\",
      \"verified_by\": null,
      \"impact_if_wrong\": \"what breaks if assumption is wrong\",
      \"suggested_verification\": \"how to check\"
    }
  ]
}"

  # Try to parse the response as JSON directly
  local parsed=""
  if parsed=$(echo "$LAST_RESPONSE_TEXT" | jq '.' 2>/dev/null); then
    _jq_update --argjson s "$parsed" \
      '.semantic = (.semantic + $s)'
    log OK "Authoring summary extracted and saved to state"
    _save_assumptions "$parsed"
    return 0
  fi

  # Claude may have wrapped JSON in markdown fences — extract and retry
  local extracted
  extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n '/^```\(json\)\{0,1\}$/,/^```$/p' | sed '1d;$d')
  if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
    _jq_update --argjson s "$parsed" \
      '.semantic = (.semantic + $s)'
    log OK "Authoring summary extracted (from markdown fence) and saved to state"
    _save_assumptions "$parsed"
    return 0
  fi

  log WARN "Could not parse extraction response as JSON — semantic state will be empty"
  log WARN "Quality phases will proceed with deterministic context only"
}

# Extract assumptions to a separate file for cross-deliverable use.
_save_assumptions() {
  local parsed="$1"
  if [ "${EXPLAIN_PHASES:-true}" != "true" ]; then
    return 0
  fi

  _ensure_explain_dir
  local assumptions
  assumptions=$(echo "$parsed" | jq '.assumptions_carried_forward // []' 2>/dev/null)
  if [ -n "$assumptions" ] && [ "$assumptions" != "null" ] && [ "$assumptions" != "[]" ]; then
    echo "$assumptions" > "$EXPLAIN_DIR/assumptions.json"
    log OK "Assumptions saved to $EXPLAIN_DIR/assumptions.json"

    # Validate against invariants if artifacts available
    if [ "$HAS_ARTIFACTS" = true ]; then
      local invariants_data
      invariants_data=$(_read_artifact "invariants")
      if [ -n "$invariants_data" ]; then
        local match_count
        match_count=$(python3 -c "
import json, sys
assumptions = json.loads(sys.argv[1])
invariants = json.loads(sys.argv[2])
inv_texts = [i.get('description','').lower() for i in invariants.get('invariants',[])]
count = 0
for a in assumptions:
  words = [w for w in a.get('assumption','').lower().split() if len(w) > 4]
  for inv in inv_texts:
    if any(w in inv for w in words):
      count += 1
      break
print(count)
" "$assumptions" "$invariants_data" 2>/dev/null || echo "0")
        if [ "$match_count" -gt 0 ]; then
          log WARN "Assumptions: ${match_count} assumption(s) may relate to known invariants — review $EXPLAIN_DIR/assumptions.json"
        fi
      fi
    fi
  fi
}

# Called at the end of phase_test_fix after all tests pass.
# Maps spec requirements to test coverage, identifies gaps.
_extract_coverage_map() {
  if [ "${EXPLAIN_PHASES:-true}" != "true" ]; then
    return 0
  fi

  _ensure_explain_dir
  log INFO "Extracting coverage map..."

  # Build artifact context for failure topology
  local artifact_prompt=""
  if [ "$HAS_ARTIFACTS" = true ]; then
    local failure_topology
    failure_topology=$(_read_artifact "failure_topology")
    if [ -n "$failure_topology" ]; then
      # Trim to relevant failure modes only (first 10 to avoid prompt bloat)
      local trimmed
      trimmed=$(echo "$failure_topology" | jq '{failure_modes: .failure_modes[:10]}' 2>/dev/null || echo "")
      if [ -n "$trimmed" ]; then
        artifact_prompt+="Known failure modes for the codebase (check if any relate to this change):
\`\`\`json
${trimmed}
\`\`\`

"
      fi
    fi
  fi

  local spec_content=""
  [ -f "$SPEC_FILE" ] && spec_content=$(cat "$SPEC_FILE")

  run_claude "All tests pass. Now assess test coverage against the spec requirements.

${artifact_prompt}The spec:
---
${spec_content}
---

For each requirement or acceptance criterion in the spec, identify:
- Whether a test exists that covers it
- Which test (file:line) covers it
- Any requirement that has NO test

Also identify scenarios that are implied by the requirements but not explicitly stated — edge cases, interaction effects, error paths that a careful reader would expect to be tested.

Output ONLY valid JSON (no markdown fences, no commentary before or after):
{
  \"covered\": [
    {
      \"requirement\": \"...\",
      \"test\": \"file:line\",
      \"confidence\": \"direct|indirect\"
    }
  ],
  \"uncovered\": [
    {
      \"requirement\": \"...\",
      \"source\": \"where this requirement comes from\",
      \"severity\": \"high|medium|low\",
      \"reason\": \"why it is not covered\"
    }
  ],
  \"implicit_scenarios\": [
    {
      \"scenario\": \"...\",
      \"description\": \"...\",
      \"severity\": \"high|medium|low\"
    }
  ]
}"

  local parsed
  if parsed=$(_extract_json_from_response); then
    if [ -n "$parsed" ]; then
      echo "$parsed" > "$EXPLAIN_DIR/coverage_map.json"
      _jq_update --argjson c "$parsed" '.semantic.coverage_map = $c'
      log OK "Coverage map saved to $EXPLAIN_DIR/coverage_map.json"

      # Check for high-severity uncovered items
      local high_count
      high_count=$(echo "$parsed" | jq '[.uncovered[]? | select(.severity == "high")] | length' 2>/dev/null || echo "0")
      if [ "$high_count" -gt 0 ]; then
        log WARN "Coverage map: ${high_count} high-severity uncovered requirement(s)"
        if [ "${COVERAGE_GATE:-false}" = "true" ]; then
          log INFO "COVERAGE_GATE enabled — review gaps at: $EXPLAIN_DIR/coverage_map.json"
          log INFO "Press Enter to continue, or Ctrl+C to abort..."
          read -r
        fi
      fi
    else
      log WARN "Could not parse coverage map — continuing without it"
    fi
  else
    log WARN "Could not parse coverage map — continuing without it"
  fi
}

# Called at the authoring/quality seam after _extract_authoring_summary.
# Deterministic audit of test file diffs — counts deleted vs added test
# assertions (it/describe/expect blocks) and stores the results in state.
# The skill_chain reviewer uses these counts to justify each deletion.
# Zero LLM cost — pure git diff analysis.
_audit_test_deletions() {
  if [ "$HAS_GIT" = false ] || [ -z "$BASELINE_COMMIT" ]; then
    log WARN "No git baseline — skipping test deletion audit"
    return 0
  fi

  log INFO "Auditing test file changes..."
  cd "$PROJECT_ROOT"

  local test_diff
  # shellcheck disable=SC2086
  test_diff=$(git diff "$BASELINE_COMMIT" -- ${TEST_FILE_GLOBS[*]} 2>/dev/null || true)

  if [ -z "$test_diff" ]; then
    log OK "No test files changed — skipping audit"
    _jq_update '.semantic.test_audit = {"deleted_assertions": 0, "added_assertions": 0, "net": 0, "deleted_blocks": [], "status": "no_test_changes"}'
    return 0
  fi

  # Count deleted and added assertion/block lines
  local deleted_assertions added_assertions
  deleted_assertions=$(echo "$test_diff" | grep '^-' | grep -v '^---' | grep -cE '\b(it|test|expect|describe)\(' || true)
  added_assertions=$(echo "$test_diff" | grep '^+' | grep -v '^+++' | grep -cE '\b(it|test|expect|describe)\(' || true)
  local net=$((added_assertions - deleted_assertions))

  # Extract deleted it() block descriptions for the reviewer
  local deleted_blocks
  deleted_blocks=$(echo "$test_diff" | grep '^-' | grep -v '^---' | grep -oE "\b(it|test)\(['\"]([^'\"]+)" | sed "s/^it('//;s/^it(\"//;s/^test('//;s/^test(\"//" || true)

  # Build JSON array of deleted block names
  local blocks_json="[]"
  if [ -n "$deleted_blocks" ]; then
    blocks_json=$(echo "$deleted_blocks" | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null || echo "[]")
  fi

  _jq_update \
    --argjson d "$deleted_assertions" \
    --argjson a "$added_assertions" \
    --argjson n "$net" \
    --argjson b "$blocks_json" \
    '.semantic.test_audit = {deleted_assertions: $d, added_assertions: $a, net: $n, deleted_blocks: $b, status: "audited"}'

  if [ "$net" -lt -3 ]; then
    log WARN "Net test assertion loss: $net (deleted=$deleted_assertions, added=$added_assertions)"
    if [ -n "$deleted_blocks" ]; then
      log WARN "Deleted test blocks:"
      echo "$deleted_blocks" | while IFS= read -r line; do
        [ -n "$line" ] && log WARN "  - $line"
      done
    fi
    log WARN "skill_chain reviewer will audit each deletion for justification"
  else
    log OK "Test audit: +$added_assertions / -$deleted_assertions (net: $net)"
  fi
}

# Called after fresh_review to capture warnings, limitations, and follow-up items.
# Continues the fresh_review conversation (run_claude, not run_claude_fresh) so
# Claude has full context of what it just reviewed. The findings flow into the
# final phase's context pack, which is where "Known Limitations" comes from.
_extract_review_findings() {
  log INFO "Extracting review findings..."

  run_claude "Summarise the review you just completed as structured JSON.

Output ONLY valid JSON (no markdown fences, no commentary). Use these exact fields:

{
  \"issues_fixed\": [\"brief description of each issue you found and fixed\"],
  \"warnings\": [\"things worth noting but not blocking — limitations, edge cases, follow-up work\"],
  \"approved_files\": [\"files that passed review without issues\"]
}"

  local parsed=""
  if parsed=$(echo "$LAST_RESPONSE_TEXT" | jq '.' 2>/dev/null); then
    _jq_update --argjson f "$parsed" \
      '.semantic.review_findings = $f'
    log OK "Review findings saved to state"
    return 0
  fi

  # Try extracting from markdown fences
  local extracted
  extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n '/^```\(json\)\{0,1\}$/,/^```$/p' | sed '1d;$d')
  if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
    _jq_update --argjson f "$parsed" \
      '.semantic.review_findings = $f'
    log OK "Review findings saved to state (from markdown fence)"
    return 0
  fi

  log WARN "Could not parse review findings — final summary will lack limitation details"
}

# Called after skill_chain to capture what the code review, security audit, and
# simplification passes found and fixed. Continues the skill_chain conversation.
_extract_skill_chain_findings() {
  log INFO "Extracting skill chain findings..."

  run_claude "Summarise the code review, pattern conformance, security review, and simplification you just completed as structured JSON.

Output ONLY valid JSON (no markdown fences, no commentary). Use these exact fields:

{
  \"code_review_issues\": [\"brief description of each code quality issue found and fixed\"],
  \"pattern_conformance\": {
    \"deviations_reverted\": [\"brief description of each reverted deviation\"],
    \"deviations_kept\": [\"brief description of each kept deviation with rationale\"],
    \"patterns_conformed\": [\"list of pattern areas that conform\"]
  },
  \"security_assessment\": \"1-2 sentence summary of security findings (issues found or verified clean)\",
  \"simplifications\": [\"brief description of each simplification made\"],
  \"verified_clean\": [\"aspects verified with no issues (e.g. layer boundaries, naming, error handling)\"]
}"

  local parsed=""
  if parsed=$(echo "$LAST_RESPONSE_TEXT" | jq '.' 2>/dev/null); then
    _jq_update --argjson f "$parsed" \
      '.semantic.skill_chain_findings = $f'
    log OK "Skill chain findings saved to state"
    return 0
  fi

  local extracted
  extracted=$(echo "$LAST_RESPONSE_TEXT" | sed -n '/^```\(json\)\{0,1\}$/,/^```$/p' | sed '1d;$d')
  if [ -n "$extracted" ] && parsed=$(echo "$extracted" | jq '.' 2>/dev/null); then
    _jq_update --argjson f "$parsed" \
      '.semantic.skill_chain_findings = $f'
    log OK "Skill chain findings saved to state (from markdown fence)"
    return 0
  fi

  log WARN "Could not parse skill chain findings"
}

